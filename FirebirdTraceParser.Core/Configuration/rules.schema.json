{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Firebird Trace Parser Rules",
  "type": "object",
  "required": ["schemaVersion", "rules"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "rules": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": {
          "$ref": "#/definitions/rule"
        }
      }
    }
  },
  "definitions": {
    "rule": {
      "type": "object",
      "required": ["pattern"],
      "properties": {
        "pattern": {
          "type": "string"
        },
        "flags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["IgnoreCase", "Multiline", "Singleline", "IgnorePatternWhitespace", "ExplicitCapture"]
          },
          "default": ["IgnorePatternWhitespace"]
        },
        "description": {
          "type": "string"
        },
        "requiredGroups": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sample": {
          "type": "string"
        }
      }
    }
  }
}