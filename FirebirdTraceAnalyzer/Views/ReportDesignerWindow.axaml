<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FirebirdTraceAnalyzer.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:enums="using:FirebirdTraceAnalyzer.Enums.Reports"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="FirebirdTraceAnalyzer.Views.ReportDesignerWindow"
        x:DataType="vm:ReportDesignerViewModel"
        Title="Report Designer"
        Width="1200"
        Height="800"
        MinWidth="1000"
        MinHeight="600"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:ReportDesignerViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource Background}">

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource Surface}"
                Padding="20"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,0,1">
            
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Report Designer"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryText}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button Content="💾 Save Template"
                            Command="{Binding SaveTemplateCommand}"
                            Background="{DynamicResource Primary}"
                            Foreground="White"
                            Padding="16,8" />
                    
                    <Button Content="👁 Preview"
                            Command="{Binding GeneratePreviewCommand}"
                            Padding="16,8" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="20">

                <!-- Template Info -->
                <Border BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="16">
                    
                    <StackPanel Spacing="12">
                        <TextBlock Text="📋 Template Information"
                                   FontWeight="SemiBold"
                                   FontSize="14" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto" RowSpacing="12">
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Template Name *" FontSize="12" />
                                <TextBox Text="{Binding TemplateName}"
                                         Watermark="Enter template name..." />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Category" FontSize="12" />
                                
                                <ComboBox SelectedValue="{Binding Category}"
                                          SelectedValueBinding="{Binding Tag, RelativeSource={RelativeSource Self}}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Quick Report" Tag="{x:Static enums:ReportCategory.Quick}" />
                                    <ComboBoxItem Content="Custom Report" Tag="{x:Static enums:ReportCategory.Custom}" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
                                <TextBlock Text="Description" FontSize="12" />
                                <TextBox Text="{Binding TemplateDescription}"
                                         PlaceholderText="Enter description..."
                                         AcceptsReturn="True"
                                         Height="60" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Header Settings -->
                <Border BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="16">
                    
                    <StackPanel Spacing="12">
                        <TextBlock Text="📄 Header Settings"
                                   FontWeight="SemiBold"
                                   FontSize="14" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Report Title *" FontSize="12" />
                                <TextBox Text="{Binding ReportTitle}" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Subtitle" FontSize="12" />
                                <TextBox Text="{Binding ReportSubtitle}"
                                         Watermark="Optional..." />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="8" Orientation="Horizontal">
                                <CheckBox Content="Show Logo"
                                          IsChecked="{Binding ShowLogo}" />
                                <CheckBox Content="Show Generated Date"
                                          IsChecked="{Binding ShowGeneratedDate}" />
                            </StackPanel>
                        </Grid>

                        <Separator />

                        <TextBlock Text="Header Variables" FontWeight="Medium" FontSize="12" />
                        
                        <ScrollViewer MaxHeight="200">
                            <ItemsControl ItemsSource="{Binding AvailableVariables}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,4">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsVisible}"
                                                          VerticalAlignment="Center" />
                                                
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DisplayName}"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0" />
                                                
                                                <NumericUpDown Grid.Column="2"
                                                               Value="{Binding DisplayOrder}"
                                                               Minimum="1"
                                                               Maximum="100"
                                                               Width="80"
                                                               ShowButtonSpinner="False"
                                                               IsEnabled="{Binding IsVisible}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Body Settings -->
                <Border BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="16">
                    
                    <StackPanel Spacing="12">
                        <TextBlock Text="📊 Body Settings"
                                   FontWeight="SemiBold"
                                   FontSize="14" />

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Display Style" FontSize="12" />
                                
                                <ComboBox SelectedValue="{Binding DisplayStyle}"
                                          SelectedValueBinding="{Binding Tag, RelativeSource={RelativeSource Self}}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Table" Tag="{x:Static enums:EventDisplayStyle.Table}" />
                                    <ComboBoxItem Content="Detailed List" Tag="{x:Static enums:EventDisplayStyle.DetailedList}" />
                                    <ComboBoxItem Content="Compact" Tag="{x:Static enums:EventDisplayStyle.Compact}" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Event Limit" FontSize="12" />
                                <NumericUpDown Value="{Binding EventLimit}"
                                               Minimum="1"
                                               Maximum="10000"
                                               Watermark="No limit..."
                                               AllowSpin="True"
                                               Increment="5" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Bottom">
                                <CheckBox Content="Show Summary Statistics"
                                          IsChecked="{Binding ShowSummary}" />
                            </StackPanel>
                        </Grid>

                        <Separator />

                        <TextBlock Text="Visible Event Fields *" FontWeight="Medium" FontSize="12" />
                        
                        <ScrollViewer MaxHeight="300">
                            <ItemsControl ItemsSource="{Binding AvailableFields}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,4"
                                                BorderBrush="{DynamicResource BorderColor}"
                                                BorderThickness="0,0,0,1">
                                            
                                            <Grid ColumnDefinitions="Auto,*,100,80,80">
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsVisible}"
                                                          VerticalAlignment="Center" />
                                                
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DisplayName}"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0" />
                                                
                                                <TextBox Grid.Column="2"
                                                         Text="{Binding Format}"
                                                         PlaceholderText="Format..."
                                                         FontSize="11"
                                                         IsEnabled="{Binding IsVisible}" />
                                                
                                                <NumericUpDown Grid.Column="3"
                                                               Value="{Binding WidthPercent}"
                                                               Minimum="5"
                                                               Maximum="100"
                                                               PlaceholderText="Width%"
                                                               ShowButtonSpinner="False"
                                                               FontSize="11"
                                                               IsEnabled="{Binding IsVisible}" />
                                                
                                                <NumericUpDown Grid.Column="4"
                                                               Value="{Binding Order}"
                                                               Minimum="1"
                                                               Maximum="100"
                                                               ShowButtonSpinner="False"
                                                               FontSize="11"
                                                               IsEnabled="{Binding IsVisible}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Filters & Sorting -->
                <Border BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="16">
                    
                    <StackPanel Spacing="12">
                        <TextBlock Text="Filters And Sorting"
                                   FontWeight="SemiBold"
                                   FontSize="14" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Sort By" FontSize="12" />
                                <ComboBox ItemsSource="{Binding AvailableSorts}"
                                          SelectedItem="{Binding SelectedSort}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Bottom">
                                <CheckBox Content="Descending Order"
                                          IsChecked="{Binding SortDescending}"
                                          IsEnabled="{Binding SelectedSort, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            </StackPanel>
                        </Grid>

                        <Separator />

                        <TextBlock Text="Active Filters" FontWeight="Medium" FontSize="12" />
                        
                        <ScrollViewer MaxHeight="250">
                            <ItemsControl ItemsSource="{Binding AvailableFilters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,4">
                                            <StackPanel Spacing="4">
                                                <CheckBox Content="{Binding DisplayName}"
                                                          IsChecked="{Binding IsActive}"
                                                          FontWeight="Medium" />
                                                
                                                <!-- TODO: Add filter value selection UI based on FilterType -->
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Export Formats -->
                <Border BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="16">
                    
                    <StackPanel Spacing="12">
                        <TextBlock Text="📤 Export Formats"
                                   FontWeight="SemiBold"
                                   FontSize="14" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Text="Supported Formats" FontSize="12" />
                                
                                <ItemsControl ItemsSource="{Binding SupportedFormats}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Format}"
                                                      IsChecked="{Binding IsSupported}"
                                                      Margin="0,2" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Default Format" FontSize="12" />
                                <ComboBox SelectedValue="{Binding DefaultFormat}" 
                                          SelectedValueBinding="{Binding Tag, RelativeSource={RelativeSource Self}}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="PDF" Tag="{x:Static enums:ReportFormat.PDF}" />
                                    <ComboBoxItem Content="Word (DOCX)" Tag="{x:Static enums:ReportFormat.DOCX}" />
                                    <ComboBoxItem Content="Excel (XLSX)" Tag="{x:Static enums:ReportFormat.XLSX}" />
                                    <ComboBoxItem Content="CSV" Tag="{x:Static enums:ReportFormat.CSV}" />
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="{DynamicResource Surface}"
                Padding="20"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,1,0,0">
            
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="●"
                               Foreground="{DynamicResource WarningColor}"
                               FontSize="16"
                               IsVisible="{Binding HasUnsavedChanges}" />
                    <TextBlock Text="Unsaved changes"
                               Foreground="{DynamicResource SecondaryText}"
                               IsVisible="{Binding HasUnsavedChanges}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Save And Close"
                        Command="{Binding SaveTemplateCommand}"
                        Background="{DynamicResource Primary}"
                        Foreground="White"
                        Padding="20,8"
                        Margin="0,0,12,0" />
                
                <Button Grid.Column="2"
                        Content="Cancel"
                        Click="CancelButton_OnClick"
                        Padding="20,8" />
            </Grid>
        </Border>

    </Grid>
</Window>