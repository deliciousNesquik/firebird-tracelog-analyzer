<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FirebirdTraceAnalyzer.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:enums="using:FirebirdTraceAnalyzer.Enums"
        xmlns:converters="clr-namespace:FirebirdTraceAnalyzer.Converters"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="700"
        x:Class="FirebirdTraceAnalyzer.Views.RemoteConnectionDialog"
        x:DataType="vm:RemoteConnectionDialogViewModel"
        Title="Connect to Remote Server"
        Width="600"
        Height="700"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <converters:BoolToPasswordCharConverter x:Key="BoolToPasswordCharConverter" />
    </Window.Resources>
    
    <Design.DataContext>
        <vm:RemoteConnectionDialogViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource Background}">

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{DynamicResource Surface}"
                Padding="20"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            
            <StackPanel Spacing="8">
                <TextBlock Text="SSH Connection Settings"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryText}" />
                
                <TextBlock Text="Connect to a remote server to download trace log files"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryText}" />
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalAlignment="Stretch" >
            <StackPanel Spacing="16" Margin="20">

                <!-- Saved Profiles -->
                <StackPanel Spacing="8"
                            IsVisible="{Binding SavedProfiles.Count, Converter={x:Static ObjectConverters.IsNotNull}}">
                    
                    <TextBlock Text="Saved Profiles"
                               FontWeight="SemiBold"
                               FontSize="13" />
                    
                    <ComboBox ItemsSource="{Binding SavedProfiles}"
                              SelectedItem="{Binding SelectedProfile}"
                              PlaceholderText="Select a profile..."
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="Medium" />
                                    <TextBlock Text="{Binding Settings.Hostname}" 
                                             FontSize="11" 
                                             Foreground="{DynamicResource SecondaryText}" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <Separator />

                <!-- Server Settings -->
                <TextBlock Text="Server Settings"
                           FontWeight="SemiBold"
                           FontSize="13" />

                <StackPanel Spacing="8">
                    <TextBlock Text="Hostname / IP Address *" FontSize="12" />
                    <TextBox Text="{Binding Hostname}"
                             PlaceholderText="192.168.1.100 or server.example.com"
                             IsEnabled="{Binding !IsConnecting}" />
                </StackPanel>

                <Grid ColumnDefinitions="*,120" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock Text="Username *" FontSize="12" />
                        <TextBox Text="{Binding Username}"
                                 PlaceholderText="root"
                                 IsEnabled="{Binding !IsConnecting}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="Port *" FontSize="12" />
                        <NumericUpDown Value="{Binding Port}"
                                       Minimum="1"
                                       Maximum="65535"
                                       IsEnabled="{Binding !IsConnecting}" />
                    </StackPanel>
                </Grid>

                <Separator />

                <!-- Authentication Method -->
                <TextBlock Text="Authentication Method"
                           FontWeight="SemiBold"
                           FontSize="13" />

                <StackPanel Spacing="8">
                    <RadioButton Content="Password"
                                 IsChecked="{Binding IsPasswordAuthSelected}"
                                 Command="{Binding ChangeAuthMethodCommand}"
                                 GroupName="AuthMethod"
                                 CommandParameter="{x:Static enums:AuthenticationMethod.Password}"
                                 IsEnabled="{Binding !IsConnecting}" />

                    <Border IsVisible="{Binding IsPasswordAuthSelected}"
                            Padding="20,0,0,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Password *" FontSize="12" />
                            <TextBox Text="{Binding Password}"
                                     PasswordChar="{Binding ShowPassword, Converter={StaticResource BoolToPasswordCharConverter}}"
                                     PlaceholderText="Enter password"
                                     IsEnabled="{Binding !IsConnecting}" />

                            <CheckBox Content="Show password"
                                      IsChecked="{Binding ShowPassword}"
                                      FontSize="11" />

                            <CheckBox Content="Remember password (stored securely)"
                                      IsChecked="{Binding RememberPassword}"
                                      FontSize="11" />
                        </StackPanel>
                    </Border>

                    <RadioButton Content="Private Key"
                                 IsChecked="{Binding IsPrivateKeyAuthSelected}"
                                 Command="{Binding ChangeAuthMethodCommand}"
                                 GroupName="AuthMethod"
                                 CommandParameter="{x:Static enums:AuthenticationMethod.PrivateKey}"
                                 IsEnabled="{Binding !IsConnecting}" />

                    <Border IsVisible="{Binding IsPrivateKeyAuthSelected}"
                            Padding="20,0,0,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Private Key Path *" FontSize="12" />
                            
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0"
                                         Text="{Binding PrivateKeyPath}"
                                         PlaceholderText="~/.ssh/id_rsa"
                                         IsEnabled="{Binding !IsConnecting}" />
                                
                                <Button Grid.Column="1"
                                        Content="Browse..."
                                        Classes="focused"
                                        Command="{Binding BrowsePrivateKeyCommand}"
                                        IsEnabled="{Binding !IsConnecting}"
                                        Margin="8,0,0,0" />
                            </Grid>

                            <TextBlock Text="Key Passphrase (optional)" FontSize="12" Margin="0,8,0,0" />
                            <TextBox Text="{Binding KeyPassphrase}"
                                     PasswordChar="{Binding ShowKeyPassphrase, Converter={StaticResource BoolToPasswordCharConverter}}"
                                     PlaceholderText="Leave empty if no passphrase"
                                     IsEnabled="{Binding !IsConnecting}" />

                            <CheckBox Content="Show passphrase"
                                      IsChecked="{Binding ShowKeyPassphrase}"
                                      FontSize="11" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Separator />

                <!-- Remote Directory -->
                <TextBlock Text="Remote Directory"
                           FontWeight="SemiBold"
                           FontSize="13" />

                <StackPanel Spacing="8">
                    <TextBlock Text="Path to trace files *" FontSize="12" />
                    <TextBox Text="{Binding RemoteDirectory}"
                             PlaceholderText="/var/log/firebird/trace"
                             IsEnabled="{Binding !IsConnecting}" />
                </StackPanel>

                <CheckBox Content="Delete files from server after processing"
                          IsChecked="{Binding DeleteAfterProcessing}"
                          FontWeight="Medium">
                    <CheckBox.Styles>
                        <Style Selector="CheckBox:checked">
                            <Setter Property="Foreground" Value="{DynamicResource ErrorColor}" />
                        </Style>
                    </CheckBox.Styles>
                </CheckBox>

                <Border Background="{DynamicResource WarningBackground}"
                        BorderBrush="{DynamicResource WarningBorder}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12"
                        IsVisible="{Binding DeleteAfterProcessing}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Warning"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WarningText}" />
                        <TextBlock Text="Files will be permanently deleted from the remote server after processing. This action cannot be undone!"
                                   TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="{DynamicResource WarningText}" />
                    </StackPanel>
                </Border>

                <Separator />

                <!-- Save Profile -->
                <TextBlock Text="Save Connection Profile"
                           FontWeight="SemiBold"
                           FontSize="13" />

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBox Grid.Column="0"
                             Text="{Binding ProfileName}"
                             PlaceholderText="Profile name..."
                             IsEnabled="{Binding !IsConnecting}" />
                    
                    <Button Grid.Column="1"
                            Content="Save"
                            Classes="focused"
                            Command="{Binding SaveProfileCommand}"
                            IsEnabled="{Binding !IsConnecting}" />
                </Grid>

                <!-- Error Message -->
                <Border Background="{DynamicResource ErrorBackground}"
                        BorderBrush="{DynamicResource ErrorBorder}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12"
                        IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ErrorText}"
                               FontSize="12" />
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="{DynamicResource Surface}"
                Padding="20"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            
            <Grid RowDefinitions="Auto,Auto">
                
                <!-- Status -->
                <StackPanel Grid.Row="0" 
                           Spacing="8"
                           Margin="0,0,0,12">
                    
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryText}" />
                    
                    <ProgressBar IsIndeterminate="True"
                                 IsVisible="{Binding IsConnecting}"
                                 Height="4" />
                </StackPanel>

                <!-- Buttons -->
                <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                    
                    <Button Grid.Column="0"
                            Content="Test Connection"
                            Classes="normal"
                            Command="{Binding TestConnectionCommand}"
                            IsEnabled="{Binding !IsConnecting}"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
                        <Button Content="Connect"
                                Classes="focused"
                                Command="{Binding ConnectCommand}"
                                IsEnabled="{Binding !IsConnecting}" />
                        
                        <Button Content="Cancel"
                                Classes="danger"
                                Command="{Binding CancelCommand}"
                                IsEnabled="{Binding !IsConnecting}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

    </Grid>
</Window>