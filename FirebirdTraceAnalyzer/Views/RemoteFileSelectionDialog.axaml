<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FirebirdTraceAnalyzer.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:FirebirdTraceAnalyzer.Converters"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="FirebirdTraceAnalyzer.Views.RemoteFileSelectionDialog"
        x:DataType="vm:RemoteFileSelectionViewModel"
        Title="Select Files to Download"
        Width="800"
        Height="600"
        MinWidth="600"
        MinHeight="400"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:RemoteFileSelectionViewModel />
    </Design.DataContext>

    <Window.Resources>
        <converters:BoolToPermissionConverter  x:Key="BoolToPermissionConverter" />
        <converters:BytesToReadableSizeConverter  x:Key="BytesToReadableSizeConverter" />
    </Window.Resources>
    
    <Grid RowDefinitions="Auto,Auto,*,Auto" Background="{DynamicResource Background}">

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource Surface}"
                Padding="20"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,0,1">
            
            <StackPanel Spacing="4">
                <TextBlock Text="Select Files for Download"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryText}" />
                
                <TextBlock FontSize="12" Foreground="{DynamicResource SecondaryText}">
                    <Run Text="Server:" />
                    <Run Text="{Binding ServerInfo}" FontWeight="Medium" />
                </TextBlock>
                
                <TextBlock FontSize="12" Foreground="{DynamicResource SecondaryText}">
                    <Run Text="Directory:" />
                    <Run Text="{Binding RemoteDirectory}" FontWeight="Medium" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Search and Filters -->
        <Border Grid.Row="1"
                Background="{DynamicResource Surface}"
                Padding="20,10"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,0,1">
            
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                
                <!-- Search -->
                <TextBox Grid.Column="0"
                         Text="{Binding SearchText}"
                         PlaceholderText="Search files..."
                         VerticalContentAlignment="Center">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding ApplySearchCommand}" />
                    </TextBox.KeyBindings>
                </TextBox>

                <!-- Clear Search -->
                <Button Grid.Column="1"
                        Command="{Binding ClearSearchCommand}"
                        IsVisible="{Binding SearchText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Height="40" Width="40"
                        ToolTip.Tip="Clear search" >
                    <Button.Content>
                        <Svg Path="{DynamicResource ClearIcon}" Css="{DynamicResource ThemeIconFill}" />
                    </Button.Content>
                    
                </Button>

                <!-- Date Filter -->
                <Button Grid.Column="2" Height="40" Width="40">
                    <Button.Content>
                        <Svg Path="{DynamicResource FilterIcon}" Css="{DynamicResource ThemeIconStroke}" />
                    </Button.Content>
                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuItem Header="Today" Command="{Binding FilterByDateCommand}" CommandParameter="today" />
                            <MenuItem Header="Yesterday" Command="{Binding FilterByDateCommand}" CommandParameter="yesterday" />
                            <MenuItem Header="Last 7 days" Command="{Binding FilterByDateCommand}" CommandParameter="week" />
                            <MenuItem Header="Last 30 days" Command="{Binding FilterByDateCommand}" CommandParameter="month" />
                            <Separator />
                            <MenuItem Header="All files" Command="{Binding ClearSearchCommand}" />
                        </MenuFlyout>
                    </Button.Flyout>
                    
                </Button>

                <!-- Refresh -->
                <Button Grid.Column="3"
                        Height="40" Width="40"
                        Command="{Binding RefreshCommand}"
                        ToolTip.Tip="Refresh file list" >
                    <Button.Content>
                        <Svg Path="{DynamicResource ReloadIcon}" Css="{DynamicResource ThemeIconFill}" />
                    </Button.Content>
                </Button>
            </Grid>
        </Border>

        <!-- File List -->
        <Border Grid.Row="2"
                Background="{DynamicResource Background}"
                Padding="20">
            
            <Grid RowDefinitions="Auto,*">
                
                <!-- Selection Controls -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="12" Margin="0,0,0,12">
                    <Button Grid.Column="0"
                            Content="Select All"
                            Command="{Binding SelectAllCommand}"
                            Padding="12,6" />
                    
                    <Button Grid.Column="1"
                            Content="Deselect All"
                            Command="{Binding DeselectAllCommand}"
                            Padding="12,6" />
                </Grid>

                <!-- Files -->
                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding FilteredFiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface}"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="12"
                                        Margin="0,0,0,8">
                                    
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                        
                                        <!-- Checkbox -->
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,12,0"
                                                  Command="{Binding $parent[Window].((vm:RemoteFileSelectionViewModel)DataContext).ToggleFileSelectionCommand}"
                                                  CommandParameter="{Binding}" />

                                        <!-- File Info -->
                                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FileName}"
                                                       FontWeight="Medium"
                                                       FontSize="13" />
                                            
                                            <TextBlock FontSize="11" Foreground="{DynamicResource SecondaryText}">
                                                <Run Text="Modified:" />
                                                <Run Text="{Binding FormattedDate}" />
                                                <Run Text=" • " />
                                                <Run Text="{Binding FormattedSize}" />
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Owner -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Owner}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SecondaryText}"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0" />

                                        <!-- Permissions -->
                                        <TextBlock Grid.Column="3"
                                                   FontSize="11"
                                                   FontFamily="Consolas,Courier New,monospace"
                                                   Foreground="{DynamicResource SecondaryText}"
                                                   VerticalAlignment="Center">
                                            <Run Text="{Binding Permissions.OwnerCanRead, Converter={StaticResource BoolToPermissionConverter}, ConverterParameter=r}" />
                                            <Run Text="{Binding Permissions.OwnerCanWrite, Converter={StaticResource BoolToPermissionConverter}, ConverterParameter=w}" />
                                            <Run Text="{Binding Permissions.OwnerCanExecute, Converter={StaticResource BoolToPermissionConverter}, ConverterParameter=x}" />
                                            <Run Text="{Binding Permissions.GroupCanRead, Converter={StaticResource BoolToPermissionConverter}, ConverterParameter=r}" />
                                            <Run Text="{Binding Permissions.GroupCanWrite, Converter={StaticResource BoolToPermissionConverter}, ConverterParameter=w}" />
                                            <Run Text="{Binding Permissions.GroupCanExecute, Converter={StaticResource BoolToPermissionConverter}, ConverterParameter=x}" />
                                            <Run Text="{Binding Permissions.OthersCanRead, Converter={StaticResource BoolToPermissionConverter}, ConverterParameter=r}" />
                                            <Run Text="{Binding Permissions.OthersCanWrite, Converter={StaticResource BoolToPermissionConverter}, ConverterParameter=w}" />
                                            <Run Text="{Binding Permissions.OthersCanExecute, Converter={StaticResource BoolToPermissionConverter}, ConverterParameter=x}" />
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3"
                Background="{DynamicResource Surface}"
                Padding="20"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,1,0,0">
            
            <Grid RowDefinitions="Auto,Auto,Auto">
                
                <!-- Statistics -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                    <TextBlock Grid.Column="0"
                               Text="{Binding StatusMessage}"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryText}"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
                        <TextBlock FontSize="12">
                            <Run Text="Selected:" />
                            <Run Text="{Binding SelectedCount}" FontWeight="SemiBold" />
                            <Run Text="file(s)" />
                        </TextBlock>

                        <TextBlock FontSize="12">
                            <Run Text="Total size:" />
                            <Run Text="{Binding SelectedTotalSize, Converter={StaticResource BytesToReadableSizeConverter}}" FontWeight="SemiBold" />
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- Delete Warning -->
                <Border Grid.Row="1"
                        Background="{DynamicResource WarningBackground}"
                        BorderBrush="{DynamicResource WarningBorder}"
                        HorizontalAlignment="Center"
                        Padding="0"
                        Margin="0,0,0,12"
                        IsVisible="{Binding DeleteAfterProcessing}">
                    
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Svg Width="40" Height="40" Source="{DynamicResource WarningIcon}" Css="{DynamicResource ThemeIconFill}"/>
                        
                        <TextBlock Text="Selected files will be permanently deleted from the server after processing"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource DangerColor}" />
                    </StackPanel>
                </Border>

                <!-- Buttons -->
                <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                    
                    <CheckBox Grid.Column="0"
                              Content="Delete files from server after processing"
                              IsChecked="{Binding DeleteAfterProcessing}"
                              VerticalAlignment="Center"
                              FontWeight="Medium">
                        <CheckBox.Styles>
                            <Style Selector="CheckBox:checked">
                                <Setter Property="Foreground" Value="{DynamicResource ErrorColor}" />
                            </Style>
                        </CheckBox.Styles>
                    </CheckBox>

                    <Button Grid.Column="1"
                            Content="Download and Process"
                            Command="{Binding ConfirmCommand}"
                            Background="{DynamicResource Primary}"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Padding="20,8" />
                    
                    <Button Grid.Column="2"
                            Content="Cancel"
                            Click="CancelButton_OnClick"
                            Padding="20,8" />
                </Grid>
            </Grid>
        </Border>

    </Grid>
</Window>