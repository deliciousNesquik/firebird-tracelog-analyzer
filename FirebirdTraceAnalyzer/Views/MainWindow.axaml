<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FirebirdTraceAnalyzer.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:FirebirdTraceAnalyzer.Controls"
        xmlns:usercontrols="clr-namespace:FirebirdTraceAnalyzer.UserControls"
        xmlns:converters="clr-namespace:FirebirdTraceAnalyzer.Converters"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="600"
        x:Class="FirebirdTraceAnalyzer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app-logo.ico"
        Title="Flytic"
        MinWidth="1000"
        MinHeight="500">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Resources>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <converters:ProgressToWidthConverter x:Key="ProgressToWidthConverter" />
    </Window.Resources>

    <Grid Background="{DynamicResource Background}" RowDefinitions="30 Auto Auto * Auto, Auto">
        <Menu Grid.Row="0">

            <MenuItem Header="_Open [O]">
                <MenuItem
                    Header="_Local File [L]"
                    InputGesture="Ctrl+O"
                    HotKey="Ctrl+O"
                    Command="{Binding OpenLocalFileCommand}" />

                <MenuItem
                    Header="_Remote File [R]"
                    InputGesture="Ctrl+Alt+O"
                    HotKey="Ctrl+Alt+O"
                    IsEnabled="False" />

                <MenuItem
                    Header="_Cancel Loading [C]"
                    InputGesture="Ctrl+C"
                    HotKey="Ctrl+C"
                    Command="{Binding CancelLoadingCommand}" />

            </MenuItem>

            <MenuItem Header="_Edit [E]">
                
                <MenuItem Header="_Reparse [R]">
                    <MenuItem
                        Header="_All Files [A]"
                        InputGesture="Ctrl+R"
                        HotKey="Ctrl+R"
                        Command="{Binding ReparseAllFilesCommand}" />

                    <MenuItem
                        Header="_Selected Files [S]"
                        InputGesture="Ctrl+Alt+R"
                        HotKey="Ctrl+Alt+R"
                        Command="{Binding ReparseSelectedFilesCommand}" />
                </MenuItem>
                
                <MenuItem Header="_Close [C]">
                    <MenuItem
                        Header="_All Files [A]"
                        InputGesture="Ctrl+W"
                        HotKey="Ctrl+W"
                        Command="{Binding CloseAllFilesCommand}" />

                    <MenuItem
                        Header="_Selected Files [S]"
                        InputGesture="Ctrl+Alt+W"
                        HotKey="Ctrl+Alt+W"
                        Command="{Binding CloseSelectedFilesCommand}" />
                </MenuItem>

            </MenuItem>

            <MenuItem Header="_Window [W]">
                <MenuItem
                    Header="_Files [F]"
                    InputGesture="Ctrl+Shift+F1"
                    HotKey="Ctrl+Shift+F1"
                    Command="{Binding SwitchVisibleTraceFilesSectionCommand}"
                    ToggleType="CheckBox"
                    IsChecked="{Binding IsTraceFilesSectionVisible}"
                    StaysOpenOnClick="True" />

                <MenuItem
                    Header="_Search, Sort and Filters [S]"
                    InputGesture="Ctrl+Shift+F2"
                    HotKey="Ctrl+Shift+F2"
                    Command="{Binding SwitchVisibleSearchSectionCommand}"
                    ToggleType="CheckBox"
                    IsChecked="{Binding IsSearchSectionVisible}"
                    StaysOpenOnClick="True" />

                <MenuItem
                    Header="_Events [E]"
                    InputGesture="Ctrl+Shift+F3"
                    HotKey="Ctrl+Shift+F3"
                    IsChecked="{Binding IsEventsSectionVisible}"
                    Command="{Binding SwitchEventsSectionVisibleCommand}"
                    ToggleType="CheckBox"
                    StaysOpenOnClick="True" />

                <MenuItem
                    Header="_Statistics [S]"
                    InputGesture="Ctrl+Shift+F4"
                    HotKey="Ctrl+Shift+F4"
                    IsChecked="{Binding IsStatisticsSectionVisible}"
                    Command="{Binding SwitchStatisticsSectionVisibleCommand}"
                    ToggleType="CheckBox"
                    StaysOpenOnClick="True" />

                <MenuItem
                    Header="_Logs [L]"
                    InputGesture="Ctrl+Shift+F5"
                    HotKey="Ctrl+Shift+F5"
                    IsChecked="{Binding IsLogsSectionVisible}"
                    Command="{Binding SwitchLogsSectionVisibleCommand}"
                    ToggleType="CheckBox"
                    StaysOpenOnClick="True" />

                <Separator />
                <MenuItem
                    Header="_Reset [R]"
                    InputGesture="Ctrl+Shift+F12"
                    HotKey="Ctrl+Shift+F12"
                    Command="{Binding GoToFactorySettingsSectionCommand}" />

            </MenuItem>

            <MenuItem Header="_Settings [S]">
                <MenuItem
                    Header="Set up remote access" />

                <MenuItem
                    Header="Configure open file update" />

            </MenuItem>
        </Menu>

        <Grid Grid.Row="1"
              Background="{DynamicResource Surface}"
              IsVisible="{Binding IsTraceFilesSectionVisible}">

            <ListBox
                Padding="10"
                SelectionMode="Multiple"
                SelectedItems="{Binding SelectedFileCards}"
                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                ItemsSource="{Binding FileCards}"
                IsVisible="{Binding FileCards.Count, Converter={x:Static ObjectConverters.IsNotNull}}">

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <controls:FileCard
                            FileName="{Binding FileInfo.FileName}"
                            FileSize="{Binding FileInfo.FileSize}"
                            EventCount="{Binding FileInfo.EventCount}"
                            StartTrace="{Binding FileInfo.StartTrace}"
                            EndTrace="{Binding FileInfo.EndTrace}"
                            RemoveFileCommand="{Binding RemoveFileCommand}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- ✅ ПУСТОЕ СОСТОЯНИЕ (когда нет файлов) -->
            <Border
                Padding="40"
                IsVisible="{Binding !FileCards.Count}">

                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16"
                    MaxWidth="400">

                    <!-- Заголовок -->
                    <TextBlock
                        Text="No trace files loaded"
                        FontSize="16"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource PrimaryText}" />

                    <!-- Описание -->
                    <TextBlock
                        Text="Start by opening Firebird trace log files to analyze database events, performance metrics, and SQL queries."
                        FontSize="12"
                        TextAlignment="Center"
                        TextWrapping="Wrap"
                        Foreground="{DynamicResource SecondaryText}" />

                </StackPanel>
            </Border>

        </Grid>


        <Border Grid.Row="2" Padding="10" Background="{DynamicResource Surface}"
                IsVisible="{Binding IsSearchSectionVisible}">

            <Grid ColumnDefinitions="* Auto Auto Auto" RowDefinitions="Auto Auto" ColumnSpacing="5">
                <TextBox Grid.Row="0" Grid.Column="0"
                         Background="{DynamicResource Surface}"
                         PlaceholderText="Search by SQL text or procedure and trigger name..."
                         VerticalContentAlignment="Center"
                         Text="{Binding SearchText, Mode=TwoWay}">

                    <!-- ✅ Выполнять поиск по Enter -->
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding ExecuteSearchCommand}" />
                    </TextBox.KeyBindings>
                </TextBox>

                <!-- ✅ Кнопка поиска -->
                <Button Grid.Row="0" Grid.Column="1"
                        Background="Transparent"
                        VerticalContentAlignment="Center"
                        Height="40" Width="40"
                        BorderThickness="1"
                        Command="{Binding ExecuteSearchCommand}"
                        ToolTip.Tip="Выполнить поиск (Enter)">

                    <!-- ✅ Badge активного поиска -->
                    <Grid>
                        <Svg Path="{DynamicResource SearchIcon}"
                             Css="{DynamicResource ThemeIconFill}" />

                        <!-- Badge "активен поиск" -->
                        <Border Background="{DynamicResource Primary}"
                                CornerRadius="8"
                                Padding="4,2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,-6,-6,0"
                                IsVisible="{Binding IsSearchActive}">
                            <TextBlock Text="🔍"
                                       Foreground="White"
                                       FontSize="9"
                                       FontWeight="Bold" />
                        </Border>
                    </Grid>
                </Button>

                <!-- ✅ Кнопка сброса поиска -->
                <Button Grid.Row="0" Grid.Column="2"
                        Background="Transparent"
                        Height="40" Width="40"
                        BorderThickness="1"
                        Command="{Binding ClearSearchCommand}"
                        IsVisible="{Binding IsSearchActive}"
                        ToolTip.Tip="Очистить поиск">
                    <Svg Path="{DynamicResource CloseIcon}"
                         Css="{DynamicResource ThemeIconStroke}" />
                </Button>

                <Button Grid.Row="0"
                        Grid.Column="2"
                        Background="Transparent"
                        Height="40" Width="40"
                        BorderThickness="1">

                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight" ShowMode="Standard">
                            <Border Padding="8" MinWidth="280" MaxHeight="400">
                                <ScrollViewer MaxHeight="450">
                                    <StackPanel Spacing="8">

                                        <TextBlock Text="Sorting events"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Margin="4,2,4,8" />

                                        <!-- Группируем по категориям -->
                                        <ItemsControl ItemsSource="{Binding AvailableSortsByCategory}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Spacing="4" Margin="0,0,0,12">

                                                        <!-- Заголовок категории -->
                                                        <TextBlock Text="{Binding Key}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource AccentColor}"
                                                                   Margin="4,4,4,2" />

                                                        <!-- Сортировки в категории -->
                                                        <ItemsControl ItemsSource="{Binding}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <RadioButton
                                                                        BorderBrush="{DynamicResource AccentColor}"
                                                                        GroupName="SortSelection"
                                                                        Content="{Binding DisplayName}"
                                                                        IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SelectSortCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        Margin="8,2"
                                                                        Padding="8,4" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Separator Margin="0,0" />

                                        <CheckBox Content="Descending"
                                                  IsChecked="{Binding IsSortDescending}"
                                                  Margin="8,4" />

                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Flyout>
                    </Button.Flyout>
                    <!-- Иконка с badge -->
                    <Grid>
                        <Svg Path="{DynamicResource SortIcon}" Css="{DynamicResource ThemeIconStroke}" />

                        <!-- Badge с направлением сортировки -->
                        <Border Background="{DynamicResource Primary}"
                                CornerRadius="8"
                                Padding="5,2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,-6,-6,0"
                                IsVisible="{Binding IsSortDescending}">
                            <TextBlock
                                Text="🠇"
                                Foreground="White"
                                FontSize="9"
                                FontWeight="Bold" />
                        </Border>

                        <!-- Badge с направлением сортировки -->
                        <Border Background="{DynamicResource Primary}"
                                CornerRadius="8"
                                Padding="5,2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,-6,-6,0"
                                IsVisible="{Binding IsSortDescending, Converter={x:Static BoolConverters.Not}}">
                            <TextBlock
                                Text="🠅"
                                Foreground="White"
                                FontSize="9"
                                FontWeight="Bold" />
                        </Border>
                    </Grid>
                </Button>

                <Button Grid.Row="0" Grid.Column="3"
                        Background="Transparent"
                        Height="40" Width="40"
                        BorderThickness="1">

                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight"
                                ShowMode="Standard">  <!-- ← Не закрывается при клике -->

                            <Border Padding="12" MinWidth="400" MaxWidth="600">

                                <!-- ✅ ОДИН ScrollViewer для ВСЕГО содержимого -->
                                <ScrollViewer MaxHeight="500">

                                    <StackPanel Spacing="12" VerticalAlignment="Top">

                                        <!-- Заголовок с кнопками -->
                                        <Grid ColumnDefinitions="* Auto">
                                            <TextBlock Text="Filtering events"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       Margin="4,2,4,8" />

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                        Orientation="Horizontal" Spacing="8">

                                                <!-- Badge активных фильтров -->
                                                <Border Background="{DynamicResource Secondary}"
                                                        CornerRadius="10"
                                                        Padding="8,2"
                                                        IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.ActiveFiltersCount, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                    <TextBlock
                                                        Text="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.ActiveFiltersCount}"
                                                        VerticalAlignment="Center"
                                                        Foreground="White"
                                                        FontSize="11"
                                                        FontWeight="Bold" />
                                                </Border>

                                                <!-- Кнопка сброса -->
                                                <Button Content="Reset All"
                                                        Background="{DynamicResource Secondary}"
                                                        Foreground="White"
                                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.ResetAllFiltersCommand}"
                                                        FontSize="14"
                                                        Padding="8,4" />
                                            </StackPanel>
                                        </Grid>

                                        <Separator />

                                        <!-- Кнопка применения -->
                                        <Button
                                            Content="Apply Filter"
                                            HorizontalContentAlignment="Center"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.ApplyFiltersCommand}"
                                            HorizontalAlignment="Stretch"
                                            Background="{DynamicResource Secondary}"
                                            Foreground="White"
                                            FontWeight="SemiBold"
                                            Padding="12,8"
                                            IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.HasUnappliedChanges}" />

                                        <!-- ✅ Список фильтров БЕЗ внутреннего ScrollViewer -->
                                        <ItemsControl
                                            ItemsSource="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.FiltersByCategory}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Spacing="8">

                                                        <!-- Заголовок категории -->
                                                        <TextBlock Text="{Binding Key}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource AccentColor}"
                                                                   Margin="0,8,0,4" />

                                                        <!-- Фильтры в категории -->
                                                        <ItemsControl ItemsSource="{Binding}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border
                                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="4"
                                                                        Padding="8"
                                                                        Margin="0,4">

                                                                        <StackPanel Spacing="6">

                                                                            <!-- Заголовок фильтра -->
                                                                            <CheckBox
                                                                                Content="{Binding DisplayName}"
                                                                                IsChecked="{Binding IsActive}"
                                                                                FontWeight="Medium"
                                                                                FontSize="12" />

                                                                            <!-- Содержимое фильтра -->
                                                                            <StackPanel Spacing="4"
                                                                                    IsVisible="{Binding IsActive}"
                                                                                    Margin="20,0,0,0">

                                                                                <!-- ✅ ПОИСК (показываем только если > 10 элементов) -->
                                                                                <TextBox
                                                                                    PlaceholderText="Type to filter..."
                                                                                    Text="{Binding ValueSearchText, Mode=TwoWay}"
                                                                                    IsVisible="{Binding AvailableValues.Count, Converter={StaticResource CountToVisibilityConverter}}"
                                                                                    Margin="0,4,0,8"/>

                                                                                <!-- ✅ Список значений БЕЗ ScrollViewer -->
                                                                                <ItemsControl
                                                                                    ItemsSource="{Binding FilteredValues}"
                                                                                    MaxHeight="250"
                                                                                    IsVisible="{Binding FilteredValues.Count, Converter={x:Static ObjectConverters.IsNotNull}}">

                                                                                    <!-- ✅ Виртуализация для производительности -->
                                                                                    <ItemsControl.ItemsPanel>
                                                                                        <ItemsPanelTemplate>
                                                                                            <VirtualizingStackPanel />
                                                                                        </ItemsPanelTemplate>
                                                                                    </ItemsControl.ItemsPanel>

                                                                                    <ItemsControl.ItemTemplate>
                                                                                        <DataTemplate>
                                                                                            <CheckBox Margin="0,2">
                                                                                                <CheckBox.Content>
                                                                                                    <StackPanel
                                                                                                        Orientation="Horizontal"
                                                                                                        Spacing="6">
                                                                                                        <TextBlock
                                                                                                            Text="{Binding DisplayName}" />
                                                                                                        <TextBlock
                                                                                                            Text="{Binding Count, StringFormat='({0})'}"
                                                                                                            Foreground="{DynamicResource SecondaryText}"
                                                                                                            FontSize="11" />
                                                                                                    </StackPanel>
                                                                                                </CheckBox.Content>
                                                                                                <CheckBox.IsChecked>
                                                                                                    <Binding
                                                                                                        Path="IsSelected"
                                                                                                        Mode="TwoWay" />
                                                                                                </CheckBox.IsChecked>
                                                                                            </CheckBox>
                                                                                        </DataTemplate>
                                                                                    </ItemsControl.ItemTemplate>
                                                                                </ItemsControl>

                                                                                <!-- Range фильтры (Numeric/DateTime) -->
                                                                                <StackPanel Spacing="4"
                                                                                    IsVisible="{Binding MinValue, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                                                    <TextBlock Text="Range:"
                                                                                        FontSize="11"
                                                                                        Foreground="{DynamicResource SecondaryText}" />

                                                                                    <Grid
                                                                                        ColumnDefinitions="Auto,*,Auto,*"
                                                                                        ColumnSpacing="6">
                                                                                        <TextBlock Grid.Column="0"
                                                                                            Text="From:"
                                                                                            VerticalAlignment="Center"
                                                                                            FontSize="11" />
                                                                                        <TextBox Grid.Column="1"
                                                                                            FontSize="11"
                                                                                            Padding="4"
                                                                                            Text="{Binding CurrentMinValue, Mode=TwoWay}" />

                                                                                        <TextBlock Grid.Column="2"
                                                                                            Text="To:"
                                                                                            VerticalAlignment="Center"
                                                                                            FontSize="11" />
                                                                                        <TextBox Grid.Column="3"
                                                                                            FontSize="11"
                                                                                            Padding="4"
                                                                                            Text="{Binding CurrentMaxValue, Mode=TwoWay}" />
                                                                                    </Grid>

                                                                                    <TextBlock FontSize="10"
                                                                                        Foreground="{DynamicResource SecondaryText}">
                                                                                        <Run Text="Min:" />
                                                                                        <Run
                                                                                            Text="{Binding MinValue}" />
                                                                                        <Run Text=" | Max:" />
                                                                                        <Run
                                                                                            Text="{Binding MaxValue}" />
                                                                                    </TextBlock>
                                                                                </StackPanel>

                                                                            </StackPanel>

                                                                        </StackPanel>

                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Flyout>
                    </Button.Flyout>

                    <!-- Иконка фильтра с badge -->
                    <Grid>
                        <Svg Path="{DynamicResource FilterIcon}" Css="{DynamicResource ThemeIconStroke}" />

                        <!-- Badge с количеством активных фильтров -->
                        <Border Background="{DynamicResource Primary}"
                                CornerRadius="8"
                                Padding="4,2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,-6,-6,0"
                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.ActiveFiltersCount, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <TextBlock
                                Text="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.ActiveFiltersCount}"
                                Foreground="White"
                                FontSize="9"
                                FontWeight="Bold" />
                        </Border>
                    </Grid>
                </Button>


            </Grid>

        </Border>

        <ListBox Grid.Row="3"
                 Padding="10"
                 ItemsSource="{Binding VisibleEvents}"
                 IsVisible="{Binding IsEventsSectionVisible}"
                 Background="{DynamicResource SurfaceElevated }"
                 SelectionMode="Multiple"
                 HorizontalAlignment="Stretch">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

        </ListBox>

        <usercontrols:StatisticInfoSection
            Grid.Row="4"
            Padding="10"
            Background="{DynamicResource SurfaceElevated}"
            IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsStatisticsSectionVisible}"
            DataContext="{Binding StatisticInfoModels}" />

        <TextBlock Grid.Row="5" Background="{DynamicResource Surface}" IsVisible="{Binding IsLogsSectionVisible}"
                   Text="{Binding StatusMessage}"
                   Padding="10" />
    </Grid>
</Window>