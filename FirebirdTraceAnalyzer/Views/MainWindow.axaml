<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FirebirdTraceAnalyzer.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:usercontrols="clr-namespace:FirebirdTraceAnalyzer.UserControls"
        xmlns:converters="clr-namespace:FirebirdTraceAnalyzer.Converters"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="600"
        x:Class="FirebirdTraceAnalyzer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app-logo.ico"
        Title="Firebird Trace Analyzer"
        MinWidth="1000"
        MinHeight="500">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Resources>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
    </Window.Resources>
    
    <!-- Нативное меню для macOS и некоторых Linux-DE (зеркало статических пунктов window Menu)-->
    <NativeMenu.Menu>
        <NativeMenu>

            <NativeMenuItem Header="Open">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Local File"
                                        Gesture="Cmd+O"
                                        Command="{Binding OpenLocalFileCommand}" />
                        <NativeMenuItem Header="Remote File"
                                        Gesture="Cmd+Alt+O"
                                        Command="{Binding OpenRemoteFileCommand}" />
                        <NativeMenuItem Header="Cancel Loading"
                                        Command="{Binding CancelLoadingCommand}" />
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>

            <NativeMenuItem Header="Edit">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Reparse">
                            <NativeMenuItem.Menu>
                                <NativeMenu>
                                    <NativeMenuItem Header="All Files"
                                                    Gesture="Cmd+R"
                                                    Command="{Binding ReparseAllFilesCommand}" />
                                    <NativeMenuItem Header="Selected Files"
                                                    Gesture="Cmd+Alt+R"
                                                    Command="{Binding ReparseSelectedFilesCommand}" />
                                </NativeMenu>
                            </NativeMenuItem.Menu>
                        </NativeMenuItem>
                        <NativeMenuItem Header="Close">
                            <NativeMenuItem.Menu>
                                <NativeMenu>
                                    <NativeMenuItem Header="All Files"
                                                    Gesture="Cmd+W"
                                                    Command="{Binding CloseAllFilesCommand}" />
                                    <NativeMenuItem Header="Selected Files"
                                                    Gesture="Cmd+Alt+W"
                                                    Command="{Binding CloseSelectedFilesCommand}" />
                                </NativeMenu>
                            </NativeMenuItem.Menu>
                        </NativeMenuItem>
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>

            <!-- Reports: только статические пункты. Динамические Quick/Custom Reports
                 (ItemsSource + стили) остаются в in-window Menu — NativeMenu не поддерживает
                 шаблонизированные списки из коллекции. -->
            <NativeMenuItem Header="Reports">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Manage Templates">
                            <NativeMenuItem.Menu>
                                <NativeMenu>
                                    <NativeMenuItem Header="Create New Template..."
                                                    Command="{Binding CreateReportTemplateCommand}" />
                                    <NativeMenuItem Header="Edit Template..."
                                                    Command="{Binding EditReportTemplateCommand}" />
                                    <NativeMenuItem Header="Import Template..."
                                                    Command="{Binding ImportReportTemplateCommand}" />
                                    <NativeMenuItem Header="Export Template..."
                                                    Command="{Binding ExportReportTemplateCommand}" />
                                </NativeMenu>
                            </NativeMenuItem.Menu>
                        </NativeMenuItem>
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="Recent Reports..."
                                        Command="{Binding OpenRecentReportsCommand}" />
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>

            <NativeMenuItem Header="Window">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Files"
                                        ToggleType="CheckBox"
                                        IsChecked="{Binding IsTraceFilesSectionVisible}"
                                        Gesture="Cmd+Shift+F1"
                                        Command="{Binding SwitchVisibleTraceFilesSectionCommand}" />
                        <NativeMenuItem Header="Search, Sort and Filters"
                                        ToggleType="CheckBox"
                                        IsChecked="{Binding IsSearchSectionVisible}"
                                        Gesture="Cmd+Shift+F2"
                                        Command="{Binding SwitchVisibleSearchSectionCommand}" />
                        <NativeMenuItem Header="Events"
                                        ToggleType="CheckBox"
                                        IsChecked="{Binding IsEventsSectionVisible}"
                                        Gesture="Cmd+Shift+F3"
                                        Command="{Binding SwitchEventsSectionVisibleCommand}" />
                        <NativeMenuItem Header="Statistics"
                                        ToggleType="CheckBox"
                                        IsChecked="{Binding IsStatisticsSectionVisible}"
                                        Gesture="Cmd+Shift+F4"
                                        Command="{Binding SwitchStatisticsSectionVisibleCommand}" />
                        <NativeMenuItem Header="Logs"
                                        ToggleType="CheckBox"
                                        IsChecked="{Binding IsLogsSectionVisible}"
                                        Gesture="Cmd+Shift+F5"
                                        Command="{Binding SwitchLogsSectionVisibleCommand}" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="Reset"
                                        Gesture="Cmd+Shift+F12"
                                        Command="{Binding GoToFactorySettingsSectionCommand}" />
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>

            <NativeMenuItem Header="Settings">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Set up remote access" />
                        <NativeMenuItem Header="Configure open file update" />
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>

        </NativeMenu>
    </NativeMenu.Menu>
    

    <Grid Background="{DynamicResource Background}" RowDefinitions="30 Auto Auto * Auto, Auto">
        <usercontrols:MainMenuView Grid.Row="0" />

        <usercontrols:FileCardsSection
            Grid.Row="1"
            Background="{DynamicResource Surface}"
            IsVisible="{Binding IsTraceFilesSectionVisible}" />


        <Border Grid.Row="2" Padding="10" Background="{DynamicResource Surface}"
                IsVisible="{Binding IsSearchSectionVisible}">

            <Grid ColumnDefinitions="* Auto Auto Auto Auto" RowDefinitions="Auto Auto" ColumnSpacing="5">
                <TextBox Grid.Row="0" Grid.Column="0"
                         Background="{DynamicResource Surface}"
                         PlaceholderText="Search by SQL text or procedure and trigger name..."
                         VerticalContentAlignment="Center"
                         Text="{Binding SearchText, Mode=TwoWay}">

                    <!-- ✅ Выполнять поиск по Enter -->
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding ExecuteSearchCommand}" />
                    </TextBox.KeyBindings>
                </TextBox>
                
                <Button Grid.Row="0" Grid.Column="1"
                        Height="40" Width="40"
                        Classes="normal"
                        Command="{Binding ClearSearchCommand}"
                        IsVisible="{Binding IsSearchActive}"
                        ToolTip.Tip="Очистить поиск">
                    <Svg Width="40" Path="{DynamicResource ClearIcon}"
                         Css="{DynamicResource ThemeIconFill}" />
                </Button>
                
                <Button Grid.Row="0" Grid.Column="2"
                        Classes="normal"
                        Height="40" Width="40"
                        Command="{Binding ExecuteSearchCommand}"
                        ToolTip.Tip="Выполнить поиск (Enter)">
                    
                    <Button.Content>
                        <Grid>
                            <Svg Width="40" Path="{DynamicResource SearchIcon}"
                                 Css="{DynamicResource ThemeIconFill}" />
                            
                            <Border Background="{DynamicResource Primary}"
                                    CornerRadius="8"
                                    Padding="4,2"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,-6,-6,0"
                                    IsVisible="{Binding IsSearchActive}">
                            </Border>
                        </Grid>
                    </Button.Content>
                </Button>

                <Button Grid.Row="0"
                        Grid.Column="3"
                        Classes="normal"
                        Height="40" Width="40">

                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight" ShowMode="Standard">
                            <Border Padding="8" MinWidth="280" MaxHeight="400">
                                <ScrollViewer MaxHeight="450">
                                    <StackPanel Spacing="8">

                                        <TextBlock Text="Sorting events"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Margin="4,2,4,8" />

                                        <!-- Группируем по категориям -->
                                        <ItemsControl ItemsSource="{Binding AvailableSortsByCategory}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Spacing="4" Margin="0,0,0,12">

                                                        <!-- Заголовок категории -->
                                                        <TextBlock Text="{Binding Key}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource AccentColor}"
                                                                   Margin="4,4,4,2" />

                                                        <!-- Сортировки в категории -->
                                                        <ItemsControl ItemsSource="{Binding}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <RadioButton
                                                                        BorderBrush="{DynamicResource AccentColor}"
                                                                        GroupName="SortSelection"
                                                                        Content="{Binding DisplayName}"
                                                                        IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SelectSortCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        Margin="8,2"
                                                                        Padding="8,4" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Separator Margin="0,0" />

                                        <CheckBox Content="Descending"
                                                  IsChecked="{Binding IsSortDescending}"
                                                  Margin="8,4" />

                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Flyout>
                    </Button.Flyout>

                    <Button.Content>
                        <Grid>
                            <Svg Width="40" Path="{DynamicResource SortIcon}" Css="{DynamicResource ThemeIconStroke}" />
                        
                            <Border Background="{DynamicResource Primary}"
                                    CornerRadius="8"
                                    Padding="4,1"
                                    Width="15" Height="15"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="0,-30,-30,0"
                                    IsVisible="{Binding IsSortDescending}">
                                <TextBlock
                                    Text="🠇"
                                    Foreground="White"
                                    FontSize="9"
                                    FontWeight="Bold" />
                            </Border>
                            
                            <Border Background="{DynamicResource AccentColor}"
                                    CornerRadius="8"
                                    Padding="4,1"
                                    Width="15" Height="15"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="0,-30,-30,0"
                                    IsVisible="{Binding IsSortDescending, Converter={x:Static BoolConverters.Not}}">
                                <TextBlock
                                    Text="🠅"
                                    Foreground="White"
                                    FontSize="9"
                                    FontWeight="Bold" />
                            </Border>
                        </Grid>
                    </Button.Content>
                    
                </Button>

                <Button Grid.Row="0" Grid.Column="4"
                        Classes="normal"
                        Height="40" Width="40">

                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight"
                                ShowMode="Standard">

                            <Border Padding="12" MinWidth="400" MaxWidth="600">
                                <ScrollViewer MaxHeight="500">
                                    <StackPanel Spacing="12" VerticalAlignment="Top">

                                        <!-- Заголовок с кнопками -->
                                        <Grid ColumnDefinitions="* Auto">
                                            <TextBlock Text="Filtering events"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       Margin="4,2,4,8" />

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                        Orientation="Horizontal" Spacing="8">

                                                <!-- Кнопка сброса -->
                                                <Button Content="Reset All"
                                                        Classes="focused"
                                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.ResetAllFiltersCommand}"/>
                                            </StackPanel>
                                        </Grid>

                                        <Separator />

                                        <!-- Кнопка применения -->
                                        <Button
                                            Content="Apply Filter"
                                            Classes="focused"
                                            HorizontalContentAlignment="Center"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.ApplyFiltersCommand}"
                                            HorizontalAlignment="Stretch"
                                            IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.HasUnappliedChanges}" />

                                        <!-- ✅ Список фильтров БЕЗ внутреннего ScrollViewer -->
                                        <ItemsControl
                                            ItemsSource="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.FiltersByCategory}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Spacing="8">

                                                        <!-- Заголовок категории -->
                                                        <TextBlock Text="{Binding Key}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource AccentColor}"
                                                                   Margin="0,8,0,4" />

                                                        <!-- Фильтры в категории -->
                                                        <ItemsControl ItemsSource="{Binding}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border
                                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="4"
                                                                        Padding="8"
                                                                        Margin="0,4">

                                                                        <StackPanel Spacing="6">

                                                                            <!-- Заголовок фильтра -->
                                                                            <CheckBox
                                                                                Content="{Binding DisplayName}"
                                                                                IsChecked="{Binding IsActive}"
                                                                                FontWeight="Medium"
                                                                                FontSize="12" />

                                                                            <!-- Содержимое фильтра -->
                                                                            <StackPanel Spacing="4"
                                                                                    IsVisible="{Binding IsActive}"
                                                                                    Margin="20,0,0,0">

                                                                                <!-- ✅ ПОИСК (показываем только если > 10 элементов) -->
                                                                                <TextBox
                                                                                    PlaceholderText="Type to filter..."
                                                                                    Text="{Binding ValueSearchText, Mode=TwoWay}"
                                                                                    IsVisible="{Binding AvailableValues.Count, Converter={StaticResource CountToVisibilityConverter}}"
                                                                                    Margin="0,4,0,8"/>

                                                                                <!-- ✅ Список значений БЕЗ ScrollViewer -->
                                                                                <ItemsControl
                                                                                    ItemsSource="{Binding FilteredValues}"
                                                                                    MaxHeight="250"
                                                                                    IsVisible="{Binding FilteredValues.Count, Converter={x:Static ObjectConverters.IsNotNull}}">

                                                                                    <!-- ✅ Виртуализация для производительности -->
                                                                                    <ItemsControl.ItemsPanel>
                                                                                        <ItemsPanelTemplate>
                                                                                            <VirtualizingStackPanel />
                                                                                        </ItemsPanelTemplate>
                                                                                    </ItemsControl.ItemsPanel>

                                                                                    <ItemsControl.ItemTemplate>
                                                                                        <DataTemplate>
                                                                                            <CheckBox Margin="0,2">
                                                                                                <CheckBox.Content>
                                                                                                    <StackPanel
                                                                                                        Orientation="Horizontal"
                                                                                                        Spacing="6">
                                                                                                        <TextBlock
                                                                                                            Text="{Binding DisplayName}" />
                                                                                                        <TextBlock
                                                                                                            Text="{Binding Count, StringFormat='({0})'}"
                                                                                                            Foreground="{DynamicResource SecondaryText}"
                                                                                                            FontSize="11" />
                                                                                                    </StackPanel>
                                                                                                </CheckBox.Content>
                                                                                                <CheckBox.IsChecked>
                                                                                                    <Binding
                                                                                                        Path="IsSelected"
                                                                                                        Mode="TwoWay" />
                                                                                                </CheckBox.IsChecked>
                                                                                            </CheckBox>
                                                                                        </DataTemplate>
                                                                                    </ItemsControl.ItemTemplate>
                                                                                </ItemsControl>

                                                                                <!-- Range фильтры (Numeric/DateTime) -->
                                                                                <StackPanel Spacing="4"
                                                                                    IsVisible="{Binding MinValue, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                                                    <TextBlock Text="Range:"
                                                                                        FontSize="11"
                                                                                        Foreground="{DynamicResource SecondaryText}" />

                                                                                    <Grid
                                                                                        ColumnDefinitions="Auto,*,Auto,*"
                                                                                        ColumnSpacing="6">
                                                                                        <TextBlock Grid.Column="0"
                                                                                            Text="From:"
                                                                                            VerticalAlignment="Center"
                                                                                            FontSize="11" />
                                                                                        <TextBox Grid.Column="1"
                                                                                            FontSize="11"
                                                                                            Padding="4"
                                                                                            Text="{Binding CurrentMinValue, Mode=TwoWay}" />

                                                                                        <TextBlock Grid.Column="2"
                                                                                            Text="To:"
                                                                                            VerticalAlignment="Center"
                                                                                            FontSize="11" />
                                                                                        <TextBox Grid.Column="3"
                                                                                            FontSize="11"
                                                                                            Padding="4"
                                                                                            Text="{Binding CurrentMaxValue, Mode=TwoWay}" />
                                                                                    </Grid>

                                                                                    <TextBlock FontSize="10"
                                                                                        Foreground="{DynamicResource SecondaryText}">
                                                                                        <Run Text="Min:" />
                                                                                        <Run
                                                                                            Text="{Binding MinValue}" />
                                                                                        <Run Text=" | Max:" />
                                                                                        <Run
                                                                                            Text="{Binding MaxValue}" />
                                                                                    </TextBlock>
                                                                                </StackPanel>

                                                                            </StackPanel>

                                                                        </StackPanel>

                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Flyout>
                    </Button.Flyout>

                    <Button.Content>
                        <Grid>
                            <Svg Width="40" Path="{DynamicResource FilterIcon}" Css="{DynamicResource ThemeIconStroke}" />

                            <Border Background="{DynamicResource AccentColor}"
                                    CornerRadius="8"
                                    Padding="4,2"
                                    Width="15" Height="15"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="0,-30,-30,0"
                                    IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.ActiveFiltersCount, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <TextBlock
                                    Text="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.ActiveFiltersCount}"
                                    Foreground="White"
                                    FontSize="9"
                                    FontWeight="Bold" />
                            </Border>
                        </Grid>
                    </Button.Content>
                </Button>
            </Grid>
        </Border>
        
        <Grid Grid.Row="3">
            <ScrollViewer Background="{DynamicResource SurfaceElevated}"
                          IsVisible="{Binding IsEventsSectionVisible}">
        
                <ItemsRepeater ItemsSource="{Binding VisibleEvents}"
                               Margin="10">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <ContentPresenter Content="{Binding}" />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
        
            </ScrollViewer>
    
            <Border
                Padding="40"
                IsVisible="{Binding !VisibleEvents.Count}">

                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16"
                    MaxWidth="400">

                    <TextBlock
                        Text="No data"
                        FontSize="16"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource PrimaryText}" />

                    <TextBlock
                        Text="After processing the file(s), the data will appear here."
                        FontSize="12"
                        TextAlignment="Center"
                        TextWrapping="Wrap"
                        Foreground="{DynamicResource SecondaryText}" />

                </StackPanel>
            </Border>
        </Grid>
        
        

        <usercontrols:StatisticInfoSection
            Grid.Row="4"
            Padding="10"
            Background="{DynamicResource SurfaceElevated}"
            IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsStatisticsSectionVisible}"
            DataContext="{Binding StatisticInfoModels}" />

        <TextBlock Grid.Row="5" Background="{DynamicResource Surface}" IsVisible="{Binding IsLogsSectionVisible}"
                   Text="{Binding StatusMessage}"
                   Padding="10" />
    </Grid>
</Window>