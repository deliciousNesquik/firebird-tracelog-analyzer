<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FirebirdTraceAnalyzer.ViewModels"
             xmlns:controls="clr-namespace:FirebirdTraceAnalyzer.Controls"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="150"
             x:Class="FirebirdTraceAnalyzer.UserControls.FileCardsSection"
             x:DataType="vm:MainWindowViewModel">

    <!-- Секция с карточками загруженных trace-файлов. DataContext наследуется от хост-окна
         (MainWindowViewModel). -->
    <Grid>

        <ListBox
            Padding="10"
            SelectionMode="Multiple"
            SelectedItems="{Binding SelectedFileCards}"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ItemsSource="{Binding FileCards}"
            IsVisible="{Binding FileCards.Count, Converter={x:Static ObjectConverters.IsNotNull}}">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <controls:FileCard
                        FileName="{Binding FileInfo.FileName}"
                        FileSize="{Binding FileInfo.FileSize}"
                        EventCount="{Binding FileInfo.EventCount}"
                        StartTrace="{Binding FileInfo.StartTrace}"
                        EndTrace="{Binding FileInfo.EndTrace}"
                        RemoveFileCommand="{Binding RemoveFileCommand}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border
            Padding="40"
            IsVisible="{Binding !FileCards.Count}">

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16"
                MaxWidth="400">

                <!-- Заголовок -->
                <TextBlock
                    Text="No trace files loaded"
                    FontSize="16"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    Foreground="{DynamicResource PrimaryText}" />

                <!-- Описание -->
                <TextBlock
                    Text="Start by opening Firebird trace log files to analyze database events, performance metrics, and SQL queries."
                    FontSize="12"
                    TextAlignment="Center"
                    TextWrapping="Wrap"
                    Foreground="{DynamicResource SecondaryText}" />

            </StackPanel>
        </Border>

    </Grid>
</UserControl>
