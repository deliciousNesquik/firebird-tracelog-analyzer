<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FTV.App"
             xmlns:local="using:FTV"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        
        <StyleInclude Source="avares://FTV/Controls/FilterCard.axaml" />
        <StyleInclude Source="avares://FTV/Controls/FileCard.axaml" />
        <StyleInclude Source="avares://FTV/Controls/FocusTextBlock.axaml" />
    </Application.Styles>
</Application>