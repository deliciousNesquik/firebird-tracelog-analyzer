<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FirebirdTraceViewer.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:FirebirdTraceViewer.Controls"
        xmlns:usercontrols="clr-namespace:FirebirdTraceViewer.UserControls"
        xmlns:events="clr-namespace:FirebirdTraceViewer.Controls.EventCards"
        xmlns:local="clr-namespace:FirebirdTraceParser.Core.Models.Events;assembly=FirebirdTraceParser.Core"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="600"
        x:Class="FirebirdTraceViewer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app-logo.ico"
        Title="FireBird Trace Log Viewer"
        MinWidth="1000"
        MinHeight="500">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.DataTemplates>

        <DataTemplate DataType="local:TraceInitEvent">
            <events:TraceInitEventCard
                Timestamp="{Binding Timestamp}"
                TraceId="{Binding TraceId}"
                HexTraceId="{Binding HexTraceId}"
                SessionId="{Binding Session.SessionId}" />
        </DataTemplate>

        <DataTemplate DataType="local:TraceFinishEvent">
            <events:TraceFiniEventCard
                Timestamp="{Binding Timestamp}"
                TraceId="{Binding TraceId}"
                HexTraceId="{Binding HexTraceId}"
                SessionId="{Binding Session.SessionId}" />
        </DataTemplate>

        <DataTemplate DataType="local:AttachDatabaseEvent">

            <events:AttachDatabaseEventCard
                Timestamp="{Binding Timestamp}"
                TraceId="{Binding TraceId}"
                HexTraceId="{Binding HexTraceId}"
                DatabasePath="{Binding Attachment.DatabasePath}"
                ProcessPath="{Binding Attachment.ProcessPath}"
                ProcessId="{Binding Attachment.ProcessId}"
                Charset="{Binding Attachment.Charset}"
                User="{Binding Attachment.User}"
                Role="{Binding Attachment.Role}"
                AttachmentId="{Binding Attachment.AttachmentId}" />
        </DataTemplate>


        <DataTemplate DataType="local:DetachDatabaseEvent">
            <events:DetachDatabaseEventCard
                Timestamp="{Binding Timestamp}"
                TraceId="{Binding TraceId}"
                HexTraceId="{Binding HexTraceId}"
                DatabasePath="{Binding Attachment.DatabasePath}"
                ProcessPath="{Binding Attachment.ProcessPath}"
                ProcessId="{Binding Attachment.ProcessId}"
                Charset="{Binding Attachment.Charset}"
                User="{Binding Attachment.User}"
                Role="{Binding Attachment.Role}"
                AttachmentId="{Binding Attachment.AttachmentId}" />
        </DataTemplate>

        <DataTemplate DataType="local:StatementStartEvent">
            <events:StatementStartEventCard
                Timestamp="{Binding Timestamp}"
                TraceId="{Binding TraceId}"
                HexTraceId="{Binding HexTraceId}"
                DatabasePath="{Binding Attachment.DatabasePath}"
                ProcessPath="{Binding Attachment.ProcessPath}"
                ProcessId="{Binding Attachment.ProcessId}"
                StatementId="{Binding StatementId}"
                Charset="{Binding Attachment.Charset}"
                User="{Binding Attachment.User}"
                Role="{Binding Attachment.Role}"
                AttachmentId="{Binding Attachment.AttachmentId}"
                Sql="{Binding Sql}"
                TransactionId="{Binding Transaction.TransactionId}"
                IsolationLevel="{Binding Transaction.IsolationLevel}"
                ConsistencyMode="{Binding Transaction.ConsistencyMode}"
                LockMode="{Binding Transaction.LockMode}"
                AccessMode="{Binding Transaction.AccessMode}"
                Params="{Binding Params}" />
        </DataTemplate>

        <DataTemplate DataType="local:StatementFinishEvent">
            <events:StatementFinishEventCard
                Timestamp="{Binding Timestamp}"
                TraceId="{Binding TraceId}"
                HexTraceId="{Binding HexTraceId}"
                DatabasePath="{Binding Attachment.DatabasePath}"
                ProcessPath="{Binding Attachment.ProcessPath}"
                ProcessId="{Binding Attachment.ProcessId}"
                StatementId="{Binding StatementId}"
                Charset="{Binding Attachment.Charset}"
                User="{Binding Attachment.User}"
                Role="{Binding Attachment.Role}"
                AttachmentId="{Binding Attachment.AttachmentId}"
                Sql="{Binding Sql}"
                TransactionId="{Binding Transaction.TransactionId}"
                IsolationLevel="{Binding Transaction.IsolationLevel}"
                ConsistencyMode="{Binding Transaction.ConsistencyMode}"
                LockMode="{Binding Transaction.LockMode}"
                AccessMode="{Binding Transaction.AccessMode}"
                Params="{Binding Params}"
                ExecuteMs="{Binding Performance.ExecuteMs}"
                ReadCount="{Binding Performance.ReadCount}"
                WriteCount="{Binding Performance.WriteCount}"
                FetchCount="{Binding Performance.FetchCount}"
                MarkCount="{Binding Performance.MarkCount}" />
        </DataTemplate>


        <DataTemplate DataType="local:ProcedureStartEvent">
            <events:ProcedureStartEventCard
                Timestamp="{Binding Timestamp}"
                TraceId="{Binding TraceId}"
                HexTraceId="{Binding HexTraceId}"
                DatabasePath="{Binding Attachment.DatabasePath}"
                ProcessPath="{Binding Attachment.ProcessPath}"
                ProcessId="{Binding Attachment.ProcessId}"
                Charset="{Binding Attachment.Charset}"
                User="{Binding Attachment.User}"
                Role="{Binding Attachment.Role}"
                AttachmentId="{Binding Attachment.AttachmentId}"
                ProcedureName="{Binding ProcedureName}"
                TransactionId="{Binding Transaction.TransactionId}"
                IsolationLevel="{Binding Transaction.IsolationLevel}"
                ConsistencyMode="{Binding Transaction.ConsistencyMode}"
                LockMode="{Binding Transaction.LockMode}"
                AccessMode="{Binding Transaction.AccessMode}"
                Params="{Binding Params}" />
        </DataTemplate>

        <DataTemplate DataType="local:ProcedureFinishEvent">
            <events:ProcedureFinishEventCard
                Timestamp="{Binding Timestamp}"
                TraceId="{Binding TraceId}"
                HexTraceId="{Binding HexTraceId}"
                DatabasePath="{Binding Attachment.DatabasePath}"
                ProcessPath="{Binding Attachment.ProcessPath}"
                ProcessId="{Binding Attachment.ProcessId}"
                Charset="{Binding Attachment.Charset}"
                User="{Binding Attachment.User}"
                Role="{Binding Attachment.Role}"
                AttachmentId="{Binding Attachment.AttachmentId}"
                ProcedureName="{Binding ProcedureName}"
                TransactionId="{Binding Transaction.TransactionId}"
                IsolationLevel="{Binding Transaction.IsolationLevel}"
                ConsistencyMode="{Binding Transaction.ConsistencyMode}"
                LockMode="{Binding Transaction.LockMode}"
                AccessMode="{Binding Transaction.AccessMode}"
                Params="{Binding Params}"
                ExecuteMs="{Binding Performance.ExecuteMs}"
                ReadCount="{Binding Performance.ReadCount}"
                WriteCount="{Binding Performance.WriteCount}"
                FetchCount="{Binding Performance.FetchCount}"
                MarkCount="{Binding Performance.MarkCount}" />
        </DataTemplate>

        <DataTemplate DataType="local:TriggerStartEvent">
            <events:TriggerStartEventCard
                Timestamp="{Binding Timestamp}"
                TraceId="{Binding TraceId}"
                HexTraceId="{Binding HexTraceId}"
                DatabasePath="{Binding Attachment.DatabasePath}"
                ProcessPath="{Binding Attachment.ProcessPath}"
                ProcessId="{Binding Attachment.ProcessId}"
                Charset="{Binding Attachment.Charset}"
                User="{Binding Attachment.User}"
                Role="{Binding Attachment.Role}"
                AttachmentId="{Binding Attachment.AttachmentId}"
                TriggerName="{Binding TriggerName}"
                Table="{Binding Table}"
                Timing="{Binding Timing}"
                Event="{Binding Event}"
                TransactionId="{Binding Transaction.TransactionId}"
                IsolationLevel="{Binding Transaction.IsolationLevel}"
                ConsistencyMode="{Binding Transaction.ConsistencyMode}"
                LockMode="{Binding Transaction.LockMode}"
                AccessMode="{Binding Transaction.AccessMode}" />
        </DataTemplate>

        <DataTemplate DataType="local:TriggerFinishEvent">
            <events:TriggerFinishEventCard
                Timestamp="{Binding Timestamp}"
                TraceId="{Binding TraceId}"
                HexTraceId="{Binding HexTraceId}"
                DatabasePath="{Binding Attachment.DatabasePath}"
                ProcessPath="{Binding Attachment.ProcessPath}"
                ProcessId="{Binding Attachment.ProcessId}"
                Charset="{Binding Attachment.Charset}"
                User="{Binding Attachment.User}"
                Role="{Binding Attachment.Role}"
                AttachmentId="{Binding Attachment.AttachmentId}"
                TriggerName="{Binding TriggerName}"
                Table="{Binding Table}"
                Timing="{Binding Timing}"
                Event="{Binding Event}"
                TransactionId="{Binding Transaction.TransactionId}"
                IsolationLevel="{Binding Transaction.IsolationLevel}"
                ConsistencyMode="{Binding Transaction.ConsistencyMode}"
                LockMode="{Binding Transaction.LockMode}"
                AccessMode="{Binding Transaction.AccessMode}"
                ExecuteMs="{Binding Performance.ExecuteMs}"
                ReadCount="{Binding Performance.ReadCount}"
                WriteCount="{Binding Performance.WriteCount}"
                FetchCount="{Binding Performance.FetchCount}"
                MarkCount="{Binding Performance.MarkCount}" />
        </DataTemplate>

    </Window.DataTemplates>

    <Grid Background="{DynamicResource AppBackground}" RowDefinitions="30 Auto Auto * Auto, Auto">

        <Menu Grid.Row="0" Background="{DynamicResource AppBackground}">
            <MenuItem Header="Open" Foreground="{DynamicResource PrimaryText}">
                <MenuItem Header="Local File" Foreground="{DynamicResource PrimaryText}"
                          Command="{Binding OpenLocalFileCommand}" />
                <MenuItem Header="Remote File" Foreground="{DynamicResource PrimaryText}" IsEnabled="False" />
                <MenuItem Header="Cancel Loading" Foreground="{DynamicResource PrimaryText}"
                          Command="{Binding CancelLoadingCommand}" />
            </MenuItem>
            <MenuItem Header="Edit" Foreground="{DynamicResource PrimaryText}">
                <MenuItem Header="Reprocess all files" Foreground="{DynamicResource PrimaryText}"
                          Command="{Binding ReparseAllFilesCommand}" />
                <MenuItem Header="Reprocess selected files" Foreground="{DynamicResource PrimaryText}"
                          Command="{Binding ReparseSelectedFilesCommand}" />
            </MenuItem>
            <MenuItem Header="Window" Foreground="{DynamicResource PrimaryText}">
                <MenuItem
                    Header="Files"
                    Foreground="{DynamicResource PrimaryText}"
                    Command="{Binding SwitchVisibleTraceFilesSectionCommand}"
                    ToggleType="CheckBox"
                    IsChecked="{Binding IsTraceFilesSectionVisible}"
                    StaysOpenOnClick="True" />

                <MenuItem
                    Header="Search, Sort and Filters"
                    Foreground="{DynamicResource PrimaryText}"
                    Command="{Binding SwitchVisibleSearchSectionCommand}"
                    ToggleType="CheckBox"
                    IsChecked="{Binding IsSearchSectionVisible}"
                    StaysOpenOnClick="True" />

                <MenuItem
                    Header="Events"
                    Foreground="{DynamicResource PrimaryText}"
                    IsChecked="{Binding IsEventsSectionVisible}"
                    Command="{Binding SwitchEventsSectionVisibleCommand}"
                    ToggleType="CheckBox"
                    StaysOpenOnClick="True" />

                <MenuItem
                    Header="Statistics"
                    Foreground="{DynamicResource PrimaryText}"
                    IsChecked="{Binding IsStatisticsSectionVisible}"
                    Command="{Binding SwitchStatisticsSectionVisibleCommand}"
                    ToggleType="CheckBox"
                    StaysOpenOnClick="True" />

                <MenuItem
                    Header="Statuses"
                    Foreground="{DynamicResource PrimaryText}"
                    IsChecked="{Binding IsLogsSectionVisible}"
                    Command="{Binding SwitchLogsSectionVisibleCommand}"
                    ToggleType="CheckBox"
                    StaysOpenOnClick="True" />

                <Separator />
                <MenuItem Header="Reset" Foreground="{DynamicResource PrimaryText}"
                          Command="{Binding GoToFactorySettingsSectionCommand}" />
            </MenuItem>

            <MenuItem Header="Settings" Foreground="{DynamicResource PrimaryText}">
                <MenuItem Header="Set up remote access" Foreground="{DynamicResource PrimaryText}" />
                <MenuItem Header="Configure open file update" Foreground="{DynamicResource PrimaryText}" />
            </MenuItem>
        </Menu>


        <ListBox
            Grid.Row="1"
            Padding="10"
            Background="{DynamicResource SecondaryBackground}"
            IsVisible="{Binding IsTraceFilesSectionVisible}"
            SelectionMode="Multiple"
            SelectedItems="{Binding SelectedFileCards}"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ItemsSource="{Binding TraceFileInfos}">

            <!-- Задаем горизонтальную ориентацию панели элементов -->
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <controls:FileCard
                        FileName="{Binding FileInfo.FileName}"
                        FileSize="{Binding FileInfo.FileSize}"
                        EventCount="{Binding FileInfo.EventCount}"
                        StartTrace="{Binding FileInfo.StartTrace}"
                        EndTrace="{Binding FileInfo.EndTrace}"
                        RemoveFileCommand="{Binding RemoveFileCommand}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2" Padding="10" Background="{DynamicResource SecondaryBackground}"
                IsVisible="{Binding IsSearchSectionVisible}">

            <!--Поисковая строка с иконкой и кнопкой поиска-->
            <Grid ColumnDefinitions="* Auto Auto Auto" RowDefinitions="Auto Auto" ColumnSpacing="5">
                <TextBox Grid.Row="0" Grid.Column="0" Background="{DynamicResource SecondaryBackground}"
                         PlaceholderText="Search" VerticalContentAlignment="Center" />
                <Button Grid.Row="0" Grid.Column="1" Background="Transparent" VerticalContentAlignment="Center"
                        Height="40" BorderThickness="1">
                    <Svg Path="{DynamicResource SearchIcon}" Css="{DynamicResource ThemeIconFill}" />
                </Button>

                <Button Grid.Row="0"
                        Grid.Column="2"
                        Background="Transparent"
                        Height="40"
                        BorderThickness="1">

                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight">
                            <Border Padding="8" MinWidth="280" MaxHeight="400">
                                <ScrollViewer MaxHeight="450">
                                    <StackPanel Spacing="8">

                                        <TextBlock Text="Сортировка событий"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Margin="4,2,4,8" />

                                        <!-- Группируем по категориям -->
                                        <ItemsControl ItemsSource="{Binding AvailableSortsByCategory}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Spacing="4" Margin="0,0,0,12">

                                                        <!-- Заголовок категории -->
                                                        <TextBlock Text="{Binding Key}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource AccentColor}"
                                                                   Margin="4,4,4,2" />

                                                        <!-- Сортировки в категории -->
                                                        <ItemsControl ItemsSource="{Binding}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <RadioButton
                                                                        BorderBrush="{DynamicResource AccentColor}"
                                                                        GroupName="SortSelection"
                                                                        Content="{Binding DisplayName}"
                                                                        IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SelectSortCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        Margin="8,2"
                                                                        Padding="8,4" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Separator Margin="0,4" />

                                        <CheckBox Content="По убыванию"
                                                  IsChecked="{Binding IsSortDescending}"
                                                  Margin="8,4" />

                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Flyout>
                    </Button.Flyout>

                    <Svg Path="{DynamicResource SortIcon}" Css="{DynamicResource ThemeIconStroke}" />
                </Button>

                <Button Grid.Row="0"
                        Grid.Column="3"
                        Background="Transparent"
                        Height="40"
                        BorderThickness="1">

                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight">
                            <Border Padding="12" MinWidth="400" MaxWidth="600" MaxHeight="500">
                                <ScrollViewer>

                                    <StackPanel Spacing="12" VerticalAlignment="Center">

                                        <!-- Заголовок -->
                                        <Grid ColumnDefinitions="* Auto">
                                            <TextBlock Grid.Column="0"
                                                       VerticalAlignment="Center"
                                                       Text="Фильтрация событий"
                                                       FontWeight="SemiBold"
                                                       FontSize="16"
                                                       Margin="0,0,0,8" />

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                        Orientation="Horizontal" Spacing="8">
                                                <!-- Badge с количеством активных фильтров -->
                                                <Border Background="{DynamicResource AccentColor}"
                                                        CornerRadius="10"
                                                        Padding="10,2"
                                                        IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.ActiveFiltersCount, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                    <TextBlock
                                                        Text="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.ActiveFiltersCount}"
                                                        VerticalAlignment="Center"
                                                        Foreground="White"
                                                        FontSize="11"
                                                        FontWeight="Bold" />
                                                </Border>

                                                <!-- Кнопка сброса -->
                                                <Button Content="Сбросить все"
                                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.ResetAllFiltersCommand}"
                                                        FontSize="12"
                                                        Padding="8,4" />
                                            </StackPanel>
                                        </Grid>

                                        <Separator />

                                        <!-- Список фильтров по категориям -->
                                        <ItemsControl
                                            ItemsSource="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.FiltersByCategory}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Spacing="8" Margin="0,0,0,16">

                                                        <!-- Заголовок категории -->
                                                        <TextBlock Text="{Binding Key}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource AccentColor}"
                                                                   Margin="0,8,0,4" />

                                                        <!-- Фильтры в категории -->
                                                        <ItemsControl ItemsSource="{Binding}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border BorderBrush="{DynamicResource BorderBrush}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="4"
                                                                            Padding="8"
                                                                            Margin="0,4">

                                                                        <StackPanel Spacing="6">

                                                                            <!-- Заголовок фильтра с чекбоксом активации -->
                                                                            <CheckBox Content="{Binding DisplayName}"
                                                                                    IsChecked="{Binding IsActive}"
                                                                                    FontWeight="Medium"
                                                                                    FontSize="12" />

                                                                            <!-- Содержимое фильтра (показываем только если активен) -->
                                                                            <StackPanel Spacing="4"
                                                                                    IsVisible="{Binding IsActive}"
                                                                                    Margin="20,0,0,0">

                                                                                <!-- Enum/String MultiSelect -->
                                                                                <ItemsControl
                                                                                    ItemsSource="{Binding AvailableValues}"
                                                                                    IsVisible="{Binding AvailableValues.Count, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                                                    <ItemsControl.ItemTemplate>
                                                                                        <DataTemplate>
                                                                                            <CheckBox Margin="0,2">
                                                                                                <CheckBox.Content>
                                                                                                    <StackPanel
                                                                                                        Orientation="Horizontal"
                                                                                                        Spacing="6">
                                                                                                        <TextBlock
                                                                                                            Text="{Binding DisplayName}" />
                                                                                                        <TextBlock
                                                                                                            Text="{Binding Count, StringFormat='({0})'}"
                                                                                                            Foreground="{DynamicResource SecondaryText}"
                                                                                                            FontSize="11" />
                                                                                                    </StackPanel>
                                                                                                </CheckBox.Content>
                                                                                                <CheckBox.IsChecked>
                                                                                                    <Binding
                                                                                                        Path="IsSelected"
                                                                                                        Mode="TwoWay" />
                                                                                                </CheckBox.IsChecked>
                                                                                            </CheckBox>
                                                                                        </DataTemplate>
                                                                                    </ItemsControl.ItemTemplate>
                                                                                </ItemsControl>

                                                                                <!-- Numeric/DateTime Range -->
                                                                                <StackPanel Spacing="4"
                                                                                    IsVisible="{Binding MinValue, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                                                    <TextBlock Text="Диапазон:"
                                                                                        FontSize="11"
                                                                                        Foreground="{DynamicResource SecondaryText}" />

                                                                                    <Grid
                                                                                        ColumnDefinitions="Auto,*,Auto,*"
                                                                                        ColumnSpacing="6">
                                                                                        <TextBlock Grid.Column="0"
                                                                                            Text="От:"
                                                                                            VerticalAlignment="Center"
                                                                                            FontSize="11" />
                                                                                        <TextBox Grid.Column="1"
                                                                                            FontSize="11"
                                                                                            Padding="4">
                                                                                            <TextBox.Text>
                                                                                                <Binding
                                                                                                    Path="CurrentMinValue"
                                                                                                    Mode="TwoWay"
                                                                                                    UpdateSourceTrigger="PropertyChanged" />
                                                                                            </TextBox.Text>
                                                                                        </TextBox>

                                                                                        <TextBlock Grid.Column="2"
                                                                                            Text="До:"
                                                                                            VerticalAlignment="Center"
                                                                                            FontSize="11" />
                                                                                        <TextBox Grid.Column="3"
                                                                                            FontSize="11"
                                                                                            Padding="4">
                                                                                            <TextBox.Text>
                                                                                                <Binding
                                                                                                    Path="CurrentMaxValue"
                                                                                                    Mode="TwoWay"
                                                                                                    UpdateSourceTrigger="PropertyChanged" />
                                                                                            </TextBox.Text>
                                                                                        </TextBox>
                                                                                    </Grid>

                                                                                    <TextBlock FontSize="10"
                                                                                        Foreground="{DynamicResource SecondaryText}">
                                                                                        <Run Text="Мин:" />
                                                                                        <Run Text="{Binding MinValue}" />
                                                                                        <Run Text=" | Макс:" />
                                                                                        <Run Text="{Binding MaxValue}" />
                                                                                    </TextBlock>
                                                                                </StackPanel>

                                                                            </StackPanel>

                                                                        </StackPanel>

                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Flyout>
                    </Button.Flyout>

                    <!-- Иконка с badge -->
                    <Grid>
                        <Svg Path="{DynamicResource FilterIcon}" Css="{DynamicResource ThemeIconStroke}" />

                        <!-- Badge с количеством активных фильтров -->
                        <Border Background="Red"
                                CornerRadius="8"
                                Padding="4,2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,-6,-6,0"
                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.ActiveFiltersCount, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <TextBlock
                                Text="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).FiltersPanelViewModel.ActiveFiltersCount}"
                                Foreground="White"
                                FontSize="9"
                                FontWeight="Bold" />
                        </Border>
                    </Grid>
                </Button>


            </Grid>

        </Border>

        <ListBox Grid.Row="3"
                 Padding="10"
                 ItemsSource="{Binding VisibleEvents}"
                 IsVisible="{Binding IsEventsSectionVisible}"
                 Background="{DynamicResource Background }"
                 SelectionMode="Multiple"
                 HorizontalAlignment="Stretch">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel CacheLength="0.5" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

        </ListBox>

        <usercontrols:StatisticInfoSection
            Grid.Row="4"
            Padding="10"
            Background="{DynamicResource SecondaryBackground}"
            IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsStatisticsSectionVisible}"
            DataContext="{Binding StatisticInfoModels}" />

        <TextBlock Grid.Row="5" Background="{DynamicResource AppBackground}" IsVisible="{Binding IsLogsSectionVisible}"
                   Text="{Binding StatusMessage}"
                   Padding="10" />
    </Grid>
</Window>