<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FirebirdTraceViewer.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:FirebirdTraceViewer.Controls"
        xmlns:local="clr-namespace:FirebirdTraceParser.Core.Models.Events;assembly=FirebirdTraceParser.Core"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="1000"
        x:Class="FirebirdTraceViewer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="FTV (firebird trace log viewer)"
        MinWidth="1000">

    <Design.DataContext>

        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.DataTemplates>

        <DataTemplate DataType="local:TraceInitEvent">
            <controls:TraceInitEventCard 
                Timestamp="{Binding Timestamp}" 
                TraceId="{Binding TraceId}"
                HexTraceId="{Binding HexTraceId}"
                SessionId="{Binding Session.SessionId}"/>
        </DataTemplate>

        <DataTemplate DataType="local:TraceFinishEvent">
            <controls:TraceFiniEventCard
                Timestamp="{Binding Timestamp}"
                TraceId="{Binding TraceId}"
                HexTraceId="{Binding HexTraceId}"
                SessionId="{Binding Session.SessionId}"/>
        </DataTemplate>



        <!-- ========================================================= -->
        <!-- ATTACH DATABASE -->
        <!-- ========================================================= -->

        <DataTemplate DataType="local:AttachDatabaseEvent">

            <controls:AttachDatabaseEventCard
                Timestamp="{Binding Timestamp}"
                TraceId="{Binding TraceId}"
                HexTraceId="{Binding HexTraceId}"
                DatabasePath="{Binding Attachment.DatabasePath}"
                ProcessPath="{Binding Attachment.ProcessPath}"
                ProcessId="{Binding Attachment.ProcessId}"
                Charset="{Binding Attachment.Charset}"
                User="{Binding Attachment.User}"
                Role="{Binding Attachment.Role}"
                AttachmentId="{Binding Attachment.AttachmentId}"/>
        </DataTemplate>
        

        <DataTemplate DataType="local:DetachDatabaseEvent">
            <controls:DetachDatabaseEventCard
                Timestamp="{Binding Timestamp}"
                TraceId="{Binding TraceId}"
                HexTraceId="{Binding HexTraceId}"
                DatabasePath="{Binding Attachment.DatabasePath}"
                ProcessPath="{Binding Attachment.ProcessPath}"
                ProcessId="{Binding Attachment.ProcessId}"
                Charset="{Binding Attachment.Charset}"
                User="{Binding Attachment.User}"
                Role="{Binding Attachment.Role}"
                AttachmentId="{Binding Attachment.AttachmentId}"/>
        </DataTemplate>



        <!-- ========================================================= -->
        <!-- STATEMENT START -->
        <!-- ========================================================= -->

        <DataTemplate DataType="local:StatementStartEvent">
            <controls:StatementStartEventCard
                Timestamp="{Binding Timestamp}"
                TraceId="{Binding TraceId}"
                HexTraceId="{Binding HexTraceId}"
                DatabasePath="{Binding Attachment.DatabasePath}"
                ProcessPath="{Binding Attachment.ProcessPath}"
                ProcessId="{Binding Attachment.ProcessId}"
                StatementId="{Binding StatementId}"
                Charset="{Binding Attachment.Charset}"
                User="{Binding Attachment.User}"
                Role="{Binding Attachment.Role}"
                AttachmentId="{Binding Attachment.AttachmentId}"
                Sql="{Binding Sql}"
                TransactionId="{Binding Transaction.TransactionId}"
                IsolationLevel="{Binding Transaction.IsolationLevel}"
                ConsistencyMode="{Binding Transaction.ConsistencyMode}"
                LockMode="{Binding Transaction.LockMode}"
                AccessMode="{Binding Transaction.AccessMode}"
                Params="{Binding Params}"/>
        </DataTemplate>



        <!-- ========================================================= -->
        <!-- STATEMENT FINISH -->
        <!-- ========================================================= -->

        <DataTemplate DataType="local:StatementFinishEvent">

            <Border Margin="0,0,0,8"
                    Padding="12"
                    CornerRadius="8"
                    BorderThickness="1">

                <StackPanel Spacing="10">

                    <Grid ColumnDefinitions="Auto,*,Auto">

                        <Border Background="#FB8C00"
                                CornerRadius="4"
                                Padding="10,4">

                            <TextBlock Text="SQL FINISH"
                                       Foreground="White"
                                       FontWeight="Bold"/>

                        </Border>

                        <TextBlock Grid.Column="1"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding Attachment.User}"
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Column="2"
                                   Text="{Binding Timestamp}"
                                   Foreground="#A0A0A0"/>

                    </Grid>

                    <Border Background="#252525"
                            Padding="10"
                            CornerRadius="6">

                        <TextBlock Text="{Binding Sql}"
                                   FontFamily="Consolas"
                                   TextWrapping="Wrap"
                                   MaxHeight="120"/>

                    </Border>

                    <Grid ColumnDefinitions="*,*,*,*">

                        <StackPanel>
                            <TextBlock Text="Elapsed"/>
                            <TextBlock Text="{Binding Performance.ExecuteMs}"
                                       FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Reads"/>
                            <TextBlock Text="{Binding Performance.ReadCount}"
                                       FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Writes"/>
                            <TextBlock Text="{Binding Performance.WriteCount}"
                                       FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3">
                            <TextBlock Text="Fetches"/>
                            <TextBlock Text="{Binding Performance.FetchCount}"
                                       FontWeight="Bold"/>
                        </StackPanel>

                    </Grid>

                </StackPanel>

            </Border>

        </DataTemplate>



        <!-- ========================================================= -->
        <!-- PROCEDURE START -->
        <!-- ========================================================= -->

        <DataTemplate DataType="local:ProcedureStartEvent">

            <Border Margin="0,0,0,8"
                    Padding="12"
                    CornerRadius="8"
                    BorderThickness="1">

                <StackPanel Spacing="10">

                    <Grid ColumnDefinitions="Auto,*,Auto">

                        <Border Background="#2E7D32"
                                CornerRadius="4"
                                Padding="10,4">

                            <TextBlock Text="PROCEDURE START"
                                       Foreground="White"
                                       FontWeight="Bold"/>

                        </Border>

                        <TextBlock Grid.Column="1"
                                   Margin="12,0,0,0"
                                   Text="{Binding ProcedureName}"
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Column="2"
                                   Text="{Binding Timestamp}"
                                   Foreground="#A0A0A0"/>

                    </Grid>

                    <TextBlock Text="{Binding Attachment.User}"/>

                </StackPanel>

            </Border>

        </DataTemplate>



        <!-- ========================================================= -->
        <!-- PROCEDURE FINISH -->
        <!-- ========================================================= -->

        <DataTemplate DataType="local:ProcedureFinishEvent">

            <Border Margin="0,0,0,8"
                    Padding="12"
                    CornerRadius="8"
                    BorderThickness="1">

                <StackPanel Spacing="10">

                    <Grid ColumnDefinitions="Auto,*,Auto">

                        <Border Background="#43A047"
                                CornerRadius="4"
                                Padding="10,4">

                            <TextBlock Text="PROCEDURE FINISH"
                                       Foreground="White"
                                       FontWeight="Bold"/>

                        </Border>

                        <TextBlock Grid.Column="1"
                                   Margin="12,0,0,0"
                                   Text="{Binding ProcedureName}"
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Column="2"
                                   Text="{Binding Timestamp}"
                                   Foreground="#A0A0A0"/>

                    </Grid>

                    <Grid ColumnDefinitions="*,*,*">

                        <StackPanel>
                            <TextBlock Text="Elapsed"/>
                            <TextBlock Text="{Binding Performance.ExecuteMs}"
                                       FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Reads"/>
                            <TextBlock Text="{Binding Performance.ReadCount}"
                                       FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Writes"/>
                            <TextBlock Text="{Binding Performance.WriteCount}"
                                       FontWeight="Bold"/>
                        </StackPanel>

                    </Grid>

                </StackPanel>

            </Border>

        </DataTemplate>



        <!-- ========================================================= -->
        <!-- TRIGGER START -->
        <!-- ========================================================= -->

        <DataTemplate DataType="local:TriggerStartEvent">

            <Border Margin="0,0,0,8"
                    Padding="12"
                    CornerRadius="8"
                    BorderThickness="1">

                <StackPanel Spacing="10">

                    <Grid ColumnDefinitions="Auto,*,Auto">

                        <Border Background="#7B1FA2"
                                CornerRadius="4"
                                Padding="10,4">

                            <TextBlock Text="TRIGGER START"
                                       Foreground="White"
                                       FontWeight="Bold"/>

                        </Border>

                        <TextBlock Grid.Column="1"
                                   Margin="12,0,0,0"
                                   Text="{Binding TriggerName}"
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Column="2"
                                   Text="{Binding Timestamp}"
                                   Foreground="#A0A0A0"/>

                    </Grid>

                    <Grid ColumnDefinitions="140,*"
                          RowDefinitions="Auto,Auto,Auto">

                        <TextBlock Text="Table:"
                                   FontWeight="Bold"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding Table}"/>

                        <TextBlock Grid.Row="1"
                                   Text="Timing:"
                                   FontWeight="Bold"/>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding Timing}"/>

                        <TextBlock Grid.Row="2"
                                   Text="Event:"
                                   FontWeight="Bold"/>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding Event}"/>

                    </Grid>

                </StackPanel>

            </Border>

        </DataTemplate>



        <!-- ========================================================= -->
        <!-- TRIGGER FINISH -->
        <!-- ========================================================= -->

        <DataTemplate DataType="local:TriggerFinishEvent">

            <Border Margin="0,0,0,8"
                    Padding="12"
                    CornerRadius="8"
                    BorderThickness="1">

                <StackPanel Spacing="10">

                    <Grid ColumnDefinitions="Auto,*,Auto">

                        <Border Background="#8E24AA"
                                CornerRadius="4"
                                Padding="10,4">

                            <TextBlock Text="TRIGGER FINISH"
                                       Foreground="White"
                                       FontWeight="Bold"/>

                        </Border>

                        <TextBlock Grid.Column="1"
                                   Margin="12,0,0,0"
                                   Text="{Binding TriggerName}"
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Column="2"
                                   Text="{Binding Timestamp}"
                                   Foreground="#A0A0A0"/>

                    </Grid>

                    <Grid ColumnDefinitions="140,*"
                          RowDefinitions="Auto,Auto,Auto">

                        <TextBlock Text="Table:"
                                   FontWeight="Bold"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding Table}"/>

                        <TextBlock Grid.Row="1"
                                   Text="Timing:"
                                   FontWeight="Bold"/>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding Timing}"/>

                        <TextBlock Grid.Row="2"
                                   Text="Event:"
                                   FontWeight="Bold"/>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding Event}"/>

                    </Grid>

                    <Grid ColumnDefinitions="*,*,*">

                        <StackPanel>
                            <TextBlock Text="Elapsed"/>
                            <TextBlock Text="{Binding Performance.ExecuteMs}"
                                       FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Reads"/>
                            <TextBlock Text="{Binding Performance.ReadCount}"
                                       FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Writes"/>
                            <TextBlock Text="{Binding Performance.WriteCount}"
                                       FontWeight="Bold"/>
                        </StackPanel>

                    </Grid>

                </StackPanel>

            </Border>

        </DataTemplate>

    </Window.DataTemplates>

    <Grid RowDefinitions="30 Auto Auto * 40, Auto" RowSpacing="5">

        <Menu Grid.Row="0">
            <MenuItem Header="Открыть">
                <MenuItem Header="Открыть локальный файл" Command="{Binding OpenLocalFileCommand}" />
                <MenuItem Header="Открыть удалённый файл" IsEnabled="False" />
            </MenuItem>
            <MenuItem Header="Редактировать">
                <MenuItem Header="Заново обработать все файлы" />
                <MenuItem Header="Заново обработать выделенные файлы" />
            </MenuItem>
            <MenuItem Header="Окна и панели">
                <MenuItem Header="Панель файлов" ToggleType="CheckBox" StaysOpenOnClick="True" />
                <MenuItem Header="Панель поиска" ToggleType="CheckBox" StaysOpenOnClick="True" />
                <MenuItem Header="Панель фильтров" ToggleType="CheckBox" StaysOpenOnClick="True" />
                <MenuItem Header="Основная панель событий" ToggleType="CheckBox" StaysOpenOnClick="True" />
                <MenuItem Header="Панель общей информации" ToggleType="CheckBox" StaysOpenOnClick="True" />
                <Separator />
                <MenuItem Header="Сбросить расположение" />
            </MenuItem>

            <MenuItem Header="Настройки">
                <MenuItem Header="Настроить удаленный доступ" />
                <MenuItem Header="Настроить обновление открытого файла" />
            </MenuItem>
        </Menu>


        <ListBox
            Grid.Row="1"
            SelectionMode="Multiple"

            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ItemsSource="{Binding TraceFileInfos}">

            <!-- Задаем горизонтальную ориентацию панели элементов -->
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <controls:FileCard
                        FileName="{Binding FileInfo.FileName}"
                        FileSize="{Binding FileInfo.FileSize}"
                        EventCount="{Binding FileInfo.EventCount}"
                        StartTrace="{Binding FileInfo.StartTrace}"
                        EndTrace="{Binding FileInfo.EndTrace}"
                        RemoveFileCommand="{Binding RemoveFileCommand}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="2" ColumnDefinitions="* *">

            <!-- Поиск -->
            <Grid Grid.Column="0" RowDefinitions="Auto Auto" Margin="10,5,10,0">

                <!-- Строка поиска (растягивается на всю ширину столбца Grid.Column="0") -->
                <Grid Grid.Row="0" ColumnDefinitions="* Auto" ColumnSpacing="10">
                    <TextBox Grid.Column="0"
                             PlaceholderText="Поиск..."
                             HorizontalAlignment="Stretch" />
                    <Button Grid.Column="1"
                            Content="🔍"
                            Width="34"
                            Height="34"
                            HorizontalAlignment="Left" />
                </Grid>

                <!-- Режимы поиска -->
                <Grid Grid.Row="1"
                      ColumnDefinitions="Auto 10* Auto"
                      ColumnSpacing="20"
                      Margin="0,8,0,0">

                    <StackPanel VerticalAlignment="Top" Grid.Column="0" Orientation="Vertical">
                        <RadioButton Content="Классический поиск"
                                     GroupName="SearchType"
                                     IsChecked="{Binding IsClassicSearch}"
                                     Command="{Binding SwitchSearchType}"
                                     HorizontalAlignment="Stretch" />
                        <RadioButton Content="Поиск регул. выражениями"
                                     GroupName="SearchType"
                                     Command="{Binding SwitchSearchType}"
                                     HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <CheckBox VerticalAlignment="Top" Grid.Column="2"
                              Content="Поиск в выбранных файлах" />
                </Grid>
            </Grid>

            <!-- Фильтрация -->
            <Grid Grid.Column="1" Margin="0,5,10,0">
                <StackPanel Orientation="Vertical" Spacing="15">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="100">
                        <ItemsControl ItemsSource="{Binding FilterCardModels}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" ItemSpacing="10" LineSpacing="10" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:FilterCard Title="{Binding Name}" Value="{Binding Value}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Orientation="Vertical" Spacing="5">
                        <Button Content="Настроить фильтры" FontWeight="Bold" BorderBrush="Black" BorderThickness="1"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Command="{Binding AddFilter}" />
                        <Button Content="Сбросить все фильтры" FontWeight="Bold" Background="Red" Foreground="White"
                                BorderBrush="Black" BorderThickness="1" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center" Command="{Binding ClearFilters}" />
                    </StackPanel>

                </StackPanel>
            </Grid>
        </Grid>

        <ListBox Grid.Row="3"
                 ItemsSource="{Binding Events}"
                 Margin="10"
                 SelectionMode="Multiple"
                 HorizontalAlignment="Stretch">
            
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

        </ListBox>

        <ItemsControl Grid.Row="4" Margin="10,5,10,10" ItemsSource="{Binding StatisticInfoModels}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" ItemSpacing="20" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <controls:FocusTextBlock Header="{Binding Header}" Value="{Binding Value}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Grid.Row="5" Text="{Binding StatusMessage}" Padding="10 0 0 5" />
    </Grid>


</Window>