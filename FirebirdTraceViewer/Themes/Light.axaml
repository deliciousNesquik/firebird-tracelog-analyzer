<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base -->
    <Color x:Key="Background">#EDEDED</Color>
    <Color x:Key="Surface">#E3E3E3</Color>
    <Color x:Key="SurfaceElevated">#DBDBDB</Color>

    <Color x:Key="Primary">#00C2FF</Color>
    <Color x:Key="PrimaryHover">#33D1FF</Color>
    <Color x:Key="PrimaryActive">#0099CC</Color>
    
    <Color x:Key="Secondary">#A0A0FF</Color>
    <Color x:Key="SecondaryMuted">#6F6FA8</Color>
    
    <!-- Controls -->
    <Color x:Key="CardBackground">#F5F5F5</Color>
    <Color x:Key="ControlBackground">#FFFFFF</Color>

    <!-- Text -->
    <Color x:Key="PrimaryText">#141414</Color>
    <Color x:Key="SecondaryText">#6B6B6B</Color>

    <!-- Borders -->
    <Color x:Key="BorderColor">#DDDDDD</Color>

    <!-- States -->
    <Color x:Key="HoverBackground">#F0F0F0</Color>
    <Color x:Key="SelectedBackground">#E8EEF9</Color>

    <!-- Accent -->
    <Color x:Key="AccentColor">#3E66AD</Color>

    <!-- Semantic -->
    <Color x:Key="SuccessColor">#2E8B57</Color>
    <Color x:Key="DangerColor">#D64545</Color>

    
    <!-- СИСТЕМНЫЕ СОБЫТИЯ (Зеленый / Красный) -->
    <Color x:Key="TraceInitEventColor">#2E7D32</Color> <!-- Темно-зеленый -->
    <Color x:Key="TraceFiniEventColor">#C62828</Color> <!-- Глубокий красный -->

    <!-- БАЗА ДАННЫХ (Синие оттенки) -->
    <Color x:Key="AttachDatabaseEventColor">#1565C0</Color> <!-- Синий -->
    <Color x:Key="DetachDatabaseEventColor">#546E7A</Color> <!-- Серо-синий -->

    <!-- ЗАПРОСЫ / STATEMENTS (Оранжевые оттенки) -->
    <Color x:Key="StatementStartEventColor">#E65100</Color> <!-- Темно-оранжевый -->
    <Color x:Key="StatementRestartEventColor">#E65100</Color> 
    <Color x:Key="StatementFinishEventColor">#FB8C00</Color> <!-- Светло-оранжевый -->
    <Color x:Key="FailedStatementFinishEventColor">#D50000</Color> <!-- Ярко-красный (Ошибка) -->

    <!-- ПРОЦЕДУРЫ (Зеленые оттенки) -->
    <Color x:Key="ProcedureStartEventColor">#1B5E20</Color> <!-- Очень темно-зеленый -->
    <Color x:Key="ProcedureRestartEventColor">#1B5E20</Color>
    <Color x:Key="ProcedureFinishEventColor">#43A047</Color> <!-- Зеленый -->
    <Color x:Key="FailedProcedureFinishEventColor">#BF360C</Color> <!-- Ржаво-красный (Ошибка) -->

    <!-- ТРИГГЕРЫ (Фиолетовые оттенки) -->
    <Color x:Key="TriggerStartEventColor">#6A1B9A</Color> <!-- Глубокий фиолетовый -->
    <Color x:Key="TriggerFinishEventColor">#8E24AA</Color> <!-- Фиолетовый -->
    <Color x:Key="FailedTriggerFinishEventColor">#AD1457</Color> <!-- Темно-розовый/Малиновый (Ошибка) -->

    <!-- КРИТИЧЕСКИЕ ОШИБКИ (Красные/Бордовые оттенки) -->
    <Color x:Key="ErrorAtJResultSetEventColor">#B71C1C</Color>
    <Color x:Key="ErrorAtJStatementEventColor">#B71C1C</Color>
    
    <!-- SVG -->
    <x:String x:Key="ThemeIconFill">
        .ThemeIconFill { fill:#141414; }
    </x:String>

    <x:String x:Key="ThemeIconStroke">
        .ThemeIconStroke { stroke:#141414; }
    </x:String>

</ResourceDictionary>