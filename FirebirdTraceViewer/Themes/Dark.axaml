<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Base -->
    <Color x:Key="Background">#121212</Color>
    <Color x:Key="Surface">#1C1C1C</Color>
    <Color x:Key="SurfaceElevated">#242424</Color>
    
    <Color x:Key="Primary">#00C2FF</Color>
    <Color x:Key="PrimaryHover">#33D1FF</Color>
    <Color x:Key="PrimaryActive">#0099CC</Color>
    
    <Color x:Key="Secondary">#A0A0FF</Color>
    <Color x:Key="SecondaryMuted">#6F6FA8</Color>
    
    <!-- Controls -->
    <Color x:Key="CardBackground">#313131</Color>
    <Color x:Key="ControlBackground">#383838</Color>

    <!-- Text -->
    <Color x:Key="PrimaryText">#F1F1F1</Color>
    <Color x:Key="SecondaryText">#B8B8B8</Color>

    <!-- Borders -->
    <Color x:Key="BorderColor">#444444</Color>

    <!-- States -->
    <Color x:Key="HoverBackground">#3B3B3B</Color>
    <Color x:Key="SelectedBackground">#31456E</Color>

    <!-- Accent -->
    <Color x:Key="AccentColor">#5B8DEF</Color>

    <!-- Semantic -->
    <Color x:Key="SuccessColor">#47B881</Color>
    <Color x:Key="DangerColor">#FF6B6B</Color>

    
    <!-- СИСТЕМНЫЕ СОБЫТИЯ (Светло-зеленый / Мягкий красный) -->
    <Color x:Key="TraceInitEventColor">#81C784</Color> <!-- Светло-зеленый -->
    <Color x:Key="TraceFiniEventColor">#E57373</Color> <!-- Мягкий красный -->

    <!-- БАЗА ДАННЫХ (Светло-синие оттенки) -->
    <Color x:Key="AttachDatabaseEventColor">#64B5F6</Color> <!-- Голубой -->
    <Color x:Key="DetachDatabaseEventColor">#90A4AE</Color> <!-- Светлый серо-синий -->

    <!-- ЗАПРОСЫ / STATEMENTS (Светло-оранжевые/Желтые оттенки) -->
    <Color x:Key="StatementStartEventColor">#FFB74D</Color> <!-- Светло-оранжевый -->
    <Color x:Key="StatementRestartEventColor">#FFB74D</Color> 
    <Color x:Key="StatementFinishEventColor">#FFE0B2</Color> <!-- Бледно-оранжевый -->
    <Color x:Key="FailedStatementFinishEventColor">#FF5252</Color> <!-- Яркий кораллово-красный (Ошибка) -->

    <!-- ПРОЦЕДУРЫ (Салатовые/Мятные оттенки) -->
    <Color x:Key="ProcedureStartEventColor">#66BB6A</Color> <!-- Приглушенный зеленый -->
    <Color x:Key="ProcedureRestartEventColor">#66BB6A</Color>
    <Color x:Key="ProcedureFinishEventColor">#A5D6A7</Color> <!-- Бледно-зеленый -->
    <Color x:Key="FailedProcedureFinishEventColor">#FF8A65</Color> <!-- Светлый терракотовый (Ошибка) -->

    <!-- ТРИГГЕРЫ (Светло-фиолетовые оттенки) -->
    <Color x:Key="TriggerStartEventColor">#BA68C8</Color> <!-- Светло-фиолетовый -->
    <Color x:Key="TriggerFinishEventColor">#E1BEE7</Color> <!-- Бледно-фиолетовый -->
    <Color x:Key="FailedTriggerFinishEventColor">#FF4081</Color> <!-- Яркий розовый (Ошибка) -->

    <!-- КРИТИЧЕСКИЕ ОШИБКИ (Яркий красный) -->
    <Color x:Key="ErrorAtJResultSetEventColor">#FF1744</Color>
    <Color x:Key="ErrorAtJStatementEventColor">#FF1744</Color>
    
    <!-- SVG -->
    <x:String x:Key="ThemeIconFill">
        .ThemeIconFill { fill:#F1F1F1; }
    </x:String>

    <x:String x:Key="ThemeIconStroke">
        .ThemeIconStroke { stroke:#F1F1F1; }
    </x:String>

</ResourceDictionary>