<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:FirebirdTraceViewer.Controls">
    <Design.PreviewWith>
        <controls:InfoTip />
    </Design.PreviewWith>

    <Style Selector="controls|InfoTip">

        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>

        <Setter Property="Template">

            <ControlTemplate>

                <Border Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        Background="#D0D0D0"
                        CornerRadius="8"
                        Cursor="Help">

                    <TextBlock Text="?"
                               FontSize="10"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">

                        <ToolTip.Tip>

                            <Border Padding="10"
                                    MaxWidth="300">

                                <TextBlock Text="{TemplateBinding Text}"
                                           TextWrapping="Wrap"/>

                            </Border>

                        </ToolTip.Tip>

                    </TextBlock>

                </Border>

            </ControlTemplate>

        </Setter>

    </Style>
</Styles>
