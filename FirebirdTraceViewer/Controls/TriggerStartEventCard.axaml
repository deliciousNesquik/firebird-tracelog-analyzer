<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:FirebirdTraceViewer.Controls"
        xmlns:models="clr-namespace:FirebirdTraceParser.Core.Models.ValueObjects;assembly=FirebirdTraceParser.Core">
    <Design.PreviewWith>
        <Border Padding="20">
            <controls:TriggerStartEventCard
                Width="900"
                Timestamp="2026 05 18 11:30:00"
                TraceId="437236" HexTraceId="0x7f3133ba1dc0"
                DatabasePath="/interbas/reid_2022.gdb"
                ProcessPath="C:\KPK_REID21_IP\KPKReplicator.exe"
                ProcessId="5432"
                Charset="WIN1251"
                User="BERDIN.A"
                TriggerName="KPK$SERVCHAINSHED_BU0"
                Table="KPK$SERVCHAINSHED"
                Timing="BEFORE"
                Event="UPDATE"
                TransactionId="13605966"
                IsolationLevel="READ_COMMITTED"
                ConsistencyMode="READ_CONSISTENCY"
                LockMode="WAIT"
                AccessMode="READ_WRITE"
                Role="ORDINARY USER"
                AttachmentId="11335646" />
        </Border>

    </Design.PreviewWith>

    <Style Selector="controls|TriggerStartEventCard">

        <Setter Property="Template">

            <ControlTemplate>

                <Border BorderThickness="1" Padding="10" BorderBrush="Black">

                    <StackPanel Spacing="10">

                        <!-- HEADER -->
                        <Grid ColumnDefinitions="Auto Auto *">

                            <!-- EVENT TYPE -->
                            <Border Grid.Column="0"
                                    Background="#7B1FA2"
                                    CornerRadius="5"
                                    Padding="16, 8, 16, 12">

                                <TextBlock Text="TRIGGER START"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="16" />
                            </Border>

                            <!-- TIMESTAMP -->
                            <TextBlock Grid.Column="2"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Text="{Binding Timestamp, RelativeSource={RelativeSource TemplatedParent}, StringFormat='{}{0:yyyy-MM-ddTHH:mm:ss.ffff}'}"
                                       FontFamily="Consolas"
                                       FontSize="16"
                                       FontWeight="DemiBold" />

                        </Grid>
                        
                        <Border>
                            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto"
                                  ColumnSpacing="30">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="TRACE ID"
                                                   FontSize="11"
                                                   Foreground="#777" />
                                        <controls:InfoTip
                                            Text="Unique identifier of trace event thread/session inside Firebird trace engine."/>
                                    </StackPanel>
                                    <TextBlock Text="{TemplateBinding TraceId}"
                                               FontWeight="Bold"
                                               Cursor="Hand"
                                               FontFamily="Consolas" />
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Spacing="4">
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="HEX"
                                                   FontSize="11"
                                                   Foreground="#777" />
                                        <controls:InfoTip
                                            Text="Unique thread/session identifier in the hex tracing event system within the Firebird tracing mechanism."/>
                                    </StackPanel>
                                    
                                    <TextBlock Text="{TemplateBinding HexTraceId}"
                                               Cursor="Hand"
                                               FontFamily="Consolas" />
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2"
                                            Spacing="4">
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="TRANSACTION ID"
                                                   FontSize="11"
                                                   Foreground="#777" />
                                        <controls:InfoTip
                                            Text="Identifies a database transaction that groups multiple SQL statements into a single unit of work."/>
                                    </StackPanel>
                                    
                                    <TextBlock Text="{TemplateBinding TransactionId}"
                                               Cursor="Hand"
                                               FontFamily="Consolas" />
                                </StackPanel>
                                
                                <StackPanel Grid.Column="3"
                                            Spacing="4">
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="ATTACHMENT ID"
                                                   FontSize="11"
                                                   Foreground="#777" />
                                        <controls:InfoTip
                                            Text="Identifies a client connection/session to the database. One attachment can contain multiple transactions and statements."/>
                                    </StackPanel>
                                    
                                    <TextBlock Text="{TemplateBinding AttachmentId}"
                                               Cursor="Hand"
                                               FontFamily="Consolas" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <WrapPanel Orientation="Horizontal"
                                   ItemSpacing="25" Margin="0 15 0 0">
                            
                            <TextBlock Text="{TemplateBinding IsolationLevel}"
                                       Cursor="Hand"
                                       FontWeight="Bold"
                                       FontFamily="Consolas" />
                            
                            <TextBlock Text="{TemplateBinding ConsistencyMode}"
                                       Cursor="Hand"
                                       FontWeight="Bold"
                                       FontFamily="Consolas" />
                            
                            <TextBlock Text="{TemplateBinding LockMode}"
                                       Cursor="Hand"
                                       FontWeight="Bold"
                                       FontFamily="Consolas" />
                            
                            <TextBlock Text="{TemplateBinding AccessMode}"
                                       Cursor="Hand"
                                       FontWeight="Bold"
                                       FontFamily="Consolas" />
                        </WrapPanel>
                        
                        <Border BorderBrush="Gray" BorderThickness="1" Padding="10">
                            <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,Auto">
                                
                                <StackPanel Orientation="Horizontal" Spacing="5">

                                    <TextBlock Text="Trigger"
                                               FontFamily="Consolas"
                                               FontWeight="Medium"/>

                                    <TextBlock Text="{TemplateBinding TriggerName}"
                                               Cursor="Hand"
                                               FontFamily="Consolas"
                                               FontWeight="Bold"/>

                                    <TextBlock Text="FOR" FontFamily="Consolas"
                                               FontWeight="Medium"/>

                                    <TextBlock Text="{TemplateBinding Table}"
                                               FontWeight="Bold"
                                               FontFamily="Consolas"/>

                                    <TextBlock Text="(" FontFamily="Consolas"
                                               FontWeight="Medium"/>

                                    <TextBlock Text="{TemplateBinding Timing}"
                                               FontWeight="Bold"
                                               FontFamily="Consolas"/>

                                    <TextBlock Text="{TemplateBinding Event}"
                                               FontWeight="Bold"
                                               FontFamily="Consolas"/>

                                    <TextBlock Text="):" FontFamily="Consolas"
                                               FontWeight="Medium"/>

                                </StackPanel>
                                
                                <Button Width="20" Height="20" Grid.Row="0" Grid.Column="1"/>
                            </Grid>
                        </Border>
                        
                    </StackPanel>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
</Styles>